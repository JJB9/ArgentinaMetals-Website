# Public Astro env vars (committed to client bundle)
PUBLIC_MAPTILER_KEY=

# Resend / Investor Alerts (server only)
# Used by netlify/functions/* and scripts/send-news-broadcast.mjs.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
# Verified sender, e.g. "alerts@mail.argentinametals.com"
RESEND_FROM_ADDRESS=alerts@argentinametals.com
# Secret used to HMAC-sign double-opt-in confirmation tokens.
# Generate with: openssl rand -base64 48
CONFIRM_TOKEN_SECRET=
# Absolute origin of the deployed site, no trailing slash, e.g. "https://argentinametals.com"
SITE_URL=https://argentinametals.com

# Contact form (server only, used by netlify/functions/submission-created.ts)
# Verified Resend sender for outgoing contact-form notifications.
RESEND_CONTACT_FROM_ADDRESS=contact@argentinametals.com
# Inbox that receives contact form submissions. Testing value below;
# switch to info@argentinametals.com when ready to go live.
CONTACT_TO_ADDRESS=amc@janbertram.com
