---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/PageHeader.astro";
---

<BaseLayout title="Investors - Argentina Metals Corp.">
  <PageHeader
    eyebrow="Investors"
    title="A tight vehicle for Argentina's copper re-rating"
    text="Investor materials, market updates, and technical reports will live here as the Astro and Decap structure expands."
  />
  <section class="content-band">
    <div class="wrap stats-grid">
      <div class="stat"><span>Land Package</span><strong>146k</strong><p>Hectares controlled</p></div>
      <div class="stat"><span>Project Areas</span><strong>26</strong><p>Across prospective districts</p></div>
      <div class="stat"><span>Targets</span><strong>100+</strong><p>GIS-ranked opportunities</p></div>
      <div class="stat"><span>Ticker</span><strong>VLLC</strong><p>TSX Venture Exchange</p></div>
    </div>
  </section>
</BaseLayout>
