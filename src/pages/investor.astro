---
import { statSync } from "node:fs";
import { resolve } from "node:path";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/PageHeader.astro";
import investorData from "../data/investor.json";

type DocItem = { icon: string; name: string; meta: string; href: string; external: boolean };

function formatSize(bytes: number): string {
  const mb = bytes / (1024 * 1024);
  return `${mb >= 10 ? mb.toFixed(0) : mb.toFixed(1)} MB`;
}

function pdfItem(icon: string, name: string, path: string | undefined, baseLabel = "PDF"): DocItem {
  if (!path) return { icon, name, meta: baseLabel, href: "#", external: false };
  try {
    const diskPath = resolve(process.cwd(), "public", path.replace(/^\//, ""));
    const bytes = statSync(diskPath).size;
    return { icon, name, meta: `${baseLabel} / ${formatSize(bytes)}`, href: path, external: true };
  } catch {
    return { icon, name, meta: baseLabel, href: path, external: true };
  }
}

function linkItem(icon: string, name: string, meta: string, href: string): DocItem {
  return { icon, name, meta, href, external: true };
}

const highlights = [
  ["category", "Pure-Play Copper", "Dedicated exposure to the critical metal driving electrification. Direct access to the geological extension of Chile's world-class copper corridor."],
  ["flag", "First-Mover Advantage", "146,000+ hectares assembled ahead of institutional capital. 100+ GIS-identified targets in terrain never systematically explored."],
  ["show_chart", "TSX-V Listing (VLLC)", "Clear path to public markets under ticker VLLC, providing liquidity and enhanced valuation metrics for shareholders."],
  ["policy", "Milei Reform Tailwind", "RIGI 30-year tax stability, profit repatriation, and streamlined permitting are validated by Glencore, BHP, and Rio Tinto commitments."],
  ["pie_chart", "Tight Capital Structure", "~60% insider ownership. Nil warrants. Top 10 shareholders own 75%+. Founder shares in 36-month escrow."],
  ["public", "Proven LatAm Team", "Combined 100+ years of experience across exploration, public markets, M&A, and Argentine operations."]
];

const documents: { title: string; items: DocItem[] }[] = [
  {
    title: "Corporate Documents",
    items: [
      pdfItem("picture_as_pdf", "Corporate Presentation", investorData.corporatePresentation),
      pdfItem("description", "Fact Sheet (1-Pager)", investorData.factSheet),
      pdfItem("science", "NI 43-101 Technical Report", investorData.technicalReport)
    ]
  },
  {
    title: "Financial Statements",
    items: [
      pdfItem("analytics", "Annual Financial Statements (Audited)", investorData.annualFinancialStatements, investorData.annualFinancialStatementsPeriod || "FY2025"),
      pdfItem("monitoring", "Interim Financial Statements", investorData.interimFinancialStatements, investorData.interimFinancialStatementsPeriod || "Q1 2026"),
      pdfItem("article", "Management Discussion & Analysis (MD&A)", investorData.mda, investorData.mdaPeriod || "Q1 2026"),
      linkItem("history", "Filing Archive", "SEDAR+ / All Years", "https://www.sedarplus.ca")
    ]
  },
  {
    title: "Regulatory Filings",
    items: [
      pdfItem("verified", "Prospectus", investorData.prospectus, investorData.prospectusPeriod || "TSXV Listing"),
      linkItem("swap_horiz", "Material Change Reports", "SEDAR+", "https://www.sedarplus.ca"),
      pdfItem("how_to_vote", "Information Circular (Proxy)", investorData.informationCircular, investorData.informationCircularPeriod || "AGM 2026"),
      linkItem("person_search", "Insider Reports", "SEDI", "https://www.sedi.ca")
    ]
  }
];
---

<BaseLayout title="Investors - Argentina Metals Corp.">
  <PageHeader
    title="Investors"
    text="Pure-play exposure to high-grade copper exploration in the world's most prospective emerging jurisdiction. TSX Venture Exchange listed."
    image="https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?auto=format&fit=crop&w=1200&q=80"
    imageAlt="Argentina Metals corporate"
    stats={[
      { value: "TSX-V: VLLC", label: "Ticker Symbol" },
      { value: "C$4.8M", label: "Capital Raised" },
      { value: "~60%", label: "Insider Ownership" }
    ]}
  />
  <section class="section soft">
    <div class="wrap">
      <div class="ticker-card" data-reveal>
        <div>
          <span>TSX-V: VLLC</span>
          <strong>Listing Pending</strong>
        </div>
        <p>Live stock data will be activated upon successful listing.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Investment Highlights</h2>
          <p class="section-desc">Six core pillars defining the Argentina Metals value proposition.</p>
        </div>
      </div>

      <div class="content-grid">
        {highlights.map(([icon, title, text], i) => (
          <article class="card icon-card" data-reveal style={`--i:${i}`}>
            <span class="mi" aria-hidden="true">{icon}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section soft" id="offering">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Current Offering</h2>
          <p class="section-desc">C$2M raise at $0.60/share to fund immediate technical programs, additional license acquisition, and TSXV listing requirements.</p>
        </div>
      </div>

      <article class="offering-card" data-reveal style="--i:1">
        <span>Series B / Pre-Listing</span>
        <h2>C$ 2,000,000 at $0.60 / Share</h2>
        <p>Pre-money valuation C$ 12.3M / Post-money C$ 14.3M / Nil warrants. Proceeds fund Phase 2 field programs, additional Mendoza licenses, and the path to public listing.</p>
        <div class="offering-grid">
          <div>
            <h3>Terms</h3>
            <dl class="terms-list">
              <div><dt>Target Raise</dt><dd>C$ 2,000,000</dd></div>
              <div><dt>Issue Price</dt><dd>$0.60 / Share</dd></div>
              <div><dt>Pre-Money Valuation</dt><dd>C$ 12.3M</dd></div>
              <div><dt>Post-Money Valuation</dt><dd>C$ 14.3M</dd></div>
              <div><dt>Warrants</dt><dd>Nil</dd></div>
            </dl>
          </div>
          <div>
            <h3>Use of Proceeds</h3>
            <div class="progress-list" data-reveal>
              <div style="--value: 40%"><span>Additional Licenses &amp; Acquisition</span><strong>40%</strong><i></i></div>
              <div style="--value: 35%"><span>Technical Work &amp; Drill Prep</span><strong>35%</strong><i></i></div>
              <div style="--value: 15%"><span>TSXV Listing &amp; Legal</span><strong>15%</strong><i></i></div>
              <div style="--value: 10%"><span>Working Capital</span><strong>10%</strong><i></i></div>
            </div>
          </div>
        </div>
        <a class="button primary" href="mailto:contact@argentinametals.com?subject=Subscription%20Agreement%20Request">Request Subscription Agreement <span class="mi" aria-hidden="true">arrow_forward</span></a>
      </article>
    </div>
  </section>

  <section class="section" id="docs">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Documents &amp; Filings</h2>
          <p class="section-desc">All continuous disclosure documents are filed on <a href="https://www.sedarplus.ca" target="_blank" rel="noopener">SEDAR+</a>. Downloads and stock information are available below.</p>
        </div>
      </div>

      <div class="document-grid">
        {documents.map((group, i) => (
          <article class="document-card" data-reveal style={`--i:${i}`}>
            <h3>{group.title}</h3>
            {group.items.map((item) => (
              <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener" : undefined}>
                <span class="mi doc-icon" aria-hidden="true">{item.icon}</span>
                <span>{item.name}</span>
                <strong>{item.meta}</strong>
              </a>
            ))}
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
