---
import { statSync } from "node:fs";
import { resolve } from "node:path";
import BaseLayout from "@layouts/BaseLayout.astro";
import SubscribeCard from "@components/SubscribeCard.astro";
import corporateDocs from "../data/investor/corporate.json";
import financialDocs from "../data/investor/financial.json";

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path}`;

type DocItem = { icon: string; name: string; meta: string; href: string; external: boolean };

function formatSize(bytes: number): string {
  const mb = bytes / (1024 * 1024);
  return `${mb >= 10 ? mb.toFixed(0) : mb.toFixed(1)} MB`;
}

function pdfItem(icon: string, name: string, path: string | undefined, baseLabel = "PDF"): DocItem {
  if (!path) return { icon, name, meta: baseLabel, href: "#", external: false };
  try {
    const diskPath = resolve(process.cwd(), "public", path.replace(/^\//, ""));
    const bytes = statSync(diskPath).size;
    return { icon, name, meta: `${baseLabel} / ${formatSize(bytes)}`, href: path, external: true };
  } catch {
    return { icon, name, meta: baseLabel, href: path, external: true };
  }
}

function linkItem(icon: string, name: string, meta: string, href: string): DocItem {
  return { icon, name, meta, href, external: true };
}

const highlights = [
  ["category", "Pure-Play Copper", "Dedicated exposure to the critical metal driving electrification. Direct access to the geological extension of Chile's world-class copper belt."],
  ["policy", "Milei Effect", "Mining-friendliness, RIGI tax regime, profit repatriation, and streamlined permitting. All validated by recent Glencore, BHP and Rio Tinto activities in Argentina."],
  ["flag", "Early Mover Advantage", "Secured ca. 150,000 hectares across prime districts in Mendoza before the emerging copper boom reshapes the region."],
  ["pie_chart", "Tight Capital Structure", "~50% insider ownership. Nil warrants. Top 10 shareholders own 75%+. Founder shares subject to 36-month TSXV Tier 2 escrow restrictions."],
  ["show_chart", "TSXV Listing", "Established path to public markets under ticker VLLC at a recognized stock exchange, providing liquidity and enhanced valuation metrics for shareholders."],
  ["public", "Team, Track Record & Technology", "Combined 100+ years of experience across exploration, public markets, M&A, and Argentine operations. Using new technologies to enhance exploration."]
];

const capitalRows = [
  { label: "Insiders", note: 1, shares: 33_773_565, pct: 47.19, color: "var(--copper-dark)" },
  { label: "Institutional & HNW", shares: 36_749_778, pct: 51.34, color: "var(--green)" },
  { label: "Non-Insider Vendors", shares: 1_050_000, pct: 1.47, color: "var(--slate)" }
];
const totalShares = capitalRows.reduce((sum, r) => sum + r.shares, 0);
const fmtShares = (n: number) => n.toLocaleString("en-US");

let donutOffset = 0;
const donutSegments = capitalRows.map((row) => {
  const segment = { ...row, dash: row.pct, offset: -donutOffset };
  donutOffset += row.pct;
  return segment;
});

const documents: { title: string; items: DocItem[] }[] = [
  {
    title: "Corporate Materials",
    items: [
      pdfItem("picture_as_pdf", "Corporate Presentation", corporateDocs.corporatePresentation),
      pdfItem("science", "NI 43-101 Technical Report: Las Estrellas", corporateDocs.technicalReport)
    ]
  },
  {
    title: "Financial Statements",
    items: [
      pdfItem("analytics", "Annual Financial Statements (Audited)", financialDocs.annualFinancialStatements, financialDocs.annualFinancialStatementsPeriod || "FY2025"),
      pdfItem("monitoring", "Interim Financial Statements", financialDocs.interimFinancialStatements, financialDocs.interimFinancialStatementsPeriod || "Q1 2026"),
      pdfItem("article", "Management Discussion & Analysis (MD&A)", financialDocs.mda, financialDocs.mdaPeriod || "Q1 2026")
    ]
  }
];
---

<BaseLayout
  title="Investors - Argentina Metals"
  description="Investor relations for Argentina Metals Corp. (TSX-V: VLLC) — corporate presentation, SEDAR+ filings, share structure, and IR contacts."
>
  <section class="page-hero page-hero--split page-hero--investor">
    <div class="wrap">
      <div class="page-hero-text">
        <h1 data-reveal style="--i:0">Investors</h1>
        <p data-reveal style="--i:1">Pure-play exposure to world-class copper exploration in one of the world's most prospective emerging jurisdictions. Listing on the TSX Venture Exchange imminently, with secondary listings on the Frankfurt and OTC Stock Exchanges to follow.</p>
      </div>
      <div class="page-hero-subscribe">
        <SubscribeCard reveal revealIndex={2} />
      </div>
    </div>
  </section>

  <div class="hero-media" data-reveal>
    <div class="hero-media-frame">
      <video
        data-parallax
        data-lazy-src={asset("videos/case-video.mp4")}
        poster={asset("images/brand/preview-thumbnail.webp")}
        autoplay
        muted
        loop
        playsinline
        preload="none"
      ></video>
    </div>
  </div>

  <script is:inline>
    (() => {
      const init = () => {
        const video = document.querySelector("video[data-lazy-src]");
        if (!video || video.dataset.lazyBound === "1") return;
        const src = video.getAttribute("data-lazy-src");
        if (!src) return;
        video.dataset.lazyBound = "1";
        const load = () => {
          if (video.src) return;
          video.src = src;
          video.load();
          const tryPlay = () => video.play().catch(() => {});
          if (video.readyState >= 2) tryPlay();
          else video.addEventListener("loadeddata", tryPlay, { once: true });
        };
        if (!("IntersectionObserver" in window)) {
          load();
          return;
        }
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              io.disconnect();
              load();
              break;
            }
          }
        }, { rootMargin: "200px 0px" });
        io.observe(video);
      };
      init();
      document.addEventListener("astro:page-load", init);
    })();
  </script>

  <section class="section">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Investment Highlights</h2>
          <p class="section-desc">Six core pillars defining Argentina Metals' value proposition.</p>
        </div>
      </div>

      <div class="content-grid">
        {highlights.map(([icon, title, text], i) => (
          <article class="card icon-card" data-reveal style={`--i:${i}`}>
            <span class="mi" aria-hidden="true">{icon}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="capital">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Capital Structure &amp; Ownership</h2>
          <p class="section-desc">Tight basic share count of {fmtShares(totalShares)} with the majority held by insiders, institutional investors, and high-net-worth individuals. Nil warrants outstanding.</p>
        </div>
      </div>

      <div class="cap-layout">
        <div class="cap-table-wrap" data-reveal>
          <div class="dtw" tabindex="0" role="region" aria-label="Capitalization table">
            <table class="dt cap-table">
              <thead>
                <tr>
                  <th scope="col">Shareholders</th>
                  <th scope="col" class="num">Shares</th>
                  <th scope="col" class="num">% of Basic S/O</th>
                </tr>
              </thead>
              <tbody>
                {capitalRows.map((row) => (
                  <tr>
                    <th scope="row">
                      <span class="cap-swatch" style={`background:${row.color}`} aria-hidden="true"></span>
                      <span>{row.label}{row.note && (<sup>({row.note})</sup>)}</span>
                    </th>
                    <td class="num">{fmtShares(row.shares)}</td>
                    <td class="num">{row.pct.toFixed(2)}%</td>
                  </tr>
                ))}
                <tr class="cap-total">
                  <th scope="row">Basic S/O</th>
                  <td class="num hi">{fmtShares(totalShares)}</td>
                  <td class="num hi">100.00%</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="cap-footnote">
            <sup>(1)</sup> Shares subject to TSXV Tier 2 Escrow Restrictions over a 36-month escrow from listing.
          </p>
        </div>

        <figure class="cap-donut" data-reveal>
          <svg viewBox="0 0 220 220" role="img" aria-labelledby="cap-donut-title cap-donut-desc">
            <title id="cap-donut-title">Ownership breakdown by shareholder group</title>
            <desc id="cap-donut-desc">Donut chart showing 47.19% insiders, 51.34% institutional and high-net-worth, and 1.47% non-insider vendors out of {fmtShares(totalShares)} basic shares outstanding.</desc>
            <circle cx="110" cy="110" r="78" fill="none" stroke="var(--sand)" stroke-width="26" />
            {donutSegments.map((seg) => (
              <circle
                cx="110"
                cy="110"
                r="78"
                fill="none"
                stroke={seg.color}
                stroke-width="26"
                pathLength="100"
                stroke-dasharray={`${seg.dash} ${100 - seg.dash}`}
                stroke-dashoffset={seg.offset}
                transform="rotate(-90 110 110)"
              />
            ))}
            <text x="110" y="104" text-anchor="middle" class="cap-donut-num">{fmtShares(totalShares)}</text>
            <text x="110" y="124" text-anchor="middle" class="cap-donut-label">Basic S/O</text>
          </svg>
          <ul class="cap-legend">
            {capitalRows.map((row) => (
              <li>
                <span class="cap-swatch" style={`background:${row.color}`} aria-hidden="true"></span>
                <span class="cap-legend-label">{row.label}</span>
                <strong class="cap-legend-pct">{row.pct.toFixed(2)}%</strong>
              </li>
            ))}
          </ul>
        </figure>
      </div>
    </div>
  </section>

  <section class="section soft" id="docs">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Documents &amp; Filings</h2>
          <p class="section-desc">Argentina Metals is a reporting issuer in Canada. The complete record of continuous disclosure filings is available on SEDAR+, with key downloads mirrored below.</p>
        </div>
      </div>

      <a
        class="sedar-card"
        href="https://www.sedarplus.ca/csa-party/records/profile.html?id=becc77e21599325466cffb9a998a42d3"
        target="_blank"
        rel="noopener"
        data-reveal
        aria-label="View Argentina Metals' company profile on SEDAR+"
      >
        <div class="sedar-card-icon" aria-hidden="true">
          <span class="mi">verified</span>
        </div>
        <div class="sedar-card-body">
          <h3>View Company Profile on SEDAR+</h3>
          <p>Access the official record of news releases, financial statements, material change reports, and insider filings filed by Argentina Metals with the Canadian Securities Administrators.</p>
        </div>
        <div class="sedar-card-cta" aria-hidden="true">
          <span class="sedar-card-cta-label">Open SEDAR+</span>
          <span class="mi sedar-card-cta-icon">north_east</span>
        </div>
      </a>

      <div class="document-grid">
        {documents.map((group, i) => (
          <article class="document-card" data-reveal style={`--i:${i}`}>
            <h3>{group.title}</h3>
            {group.items.map((item) => (
              <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener" : undefined}>
                <span class="mi doc-icon" aria-hidden="true">{item.icon}</span>
                <span>{item.name}</span>
                <strong>{item.meta}</strong>
              </a>
            ))}
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(.page-hero--split:has(.ticker-card--hero)) :global(.page-hero-text) {
    padding-bottom: 0;
  }

  :global(.ticker-card--hero) {
    position: static;
    margin-top: 28px;
    max-width: 460px;
  }

  .page-hero-subscribe {
    justify-self: end;
    align-self: center;
    width: 100%;
    max-width: 420px;
  }

  @media (max-width: 960px) {
    .page-hero-subscribe {
      justify-self: stretch;
      max-width: none;
    }
  }

  .cap-layout {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 32px;
    align-items: stretch;
  }

  .cap-table-wrap {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cap-table thead th:first-child {
    width: 44%;
  }

  .cap-table tbody th {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--g700);
    font-weight: 500;
  }

  .cap-table tbody th sup {
    margin-left: 2px;
    color: var(--g400);
    font-size: 0.65rem;
    font-weight: 500;
  }

  .cap-swatch {
    flex: none;
    width: 10px;
    height: 10px;
    border-radius: 2px;
  }

  .cap-table .cap-total th,
  .cap-table .cap-total td {
    background: var(--warm);
    color: var(--g900);
    font-weight: 600;
  }

  .cap-table .cap-total th {
    padding-left: 20px;
  }

  .cap-footnote {
    margin: 0;
    padding: 0 4px;
    color: var(--g400);
    font-size: 0.78rem;
    line-height: 1.6;
  }

  .cap-footnote sup {
    margin-right: 2px;
    color: var(--g500);
    font-weight: 500;
  }

  .cap-donut {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    margin: 0;
    padding: 36px 32px;
    background: var(--white);
    border-radius: var(--r-2xl);
    box-shadow: var(--s-sm);
  }

  .cap-donut svg {
    width: 100%;
    max-width: 260px;
    height: auto;
    display: block;
  }

  .cap-donut-num {
    font-family: var(--font-body);
    font-size: 22px;
    font-weight: 700;
    fill: var(--g900);
    letter-spacing: -0.01em;
  }

  .cap-donut-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    fill: var(--g400);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cap-legend {
    width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cap-legend li {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: var(--warm);
    border-radius: var(--r-md);
  }

  .cap-legend-label {
    color: var(--g700);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .cap-legend-pct {
    color: var(--g900);
    font-size: 0.85rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 960px) {
    .cap-layout {
      grid-template-columns: 1fr;
    }

    .cap-donut {
      padding: 28px 20px;
    }
  }

  @media (max-width: 640px) {
    .cap-table thead th:nth-child(3),
    .cap-table tbody td:nth-child(3) {
      display: none;
    }
  }

  .sedar-card {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
    padding: 26px 32px;
    margin-bottom: 28px;
    border-radius: var(--radius);
    background: var(--green-grad);
    color: #fff;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .sedar-card:hover,
  .sedar-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md, var(--shadow-sm));
  }

  .sedar-card-icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.16);
  }

  .sedar-card-icon .mi {
    font-size: 1.5rem;
    color: var(--copper-light);
  }

  .sedar-card-body {
    flex: 1 1 320px;
    min-width: 0;
  }

  .sedar-card-body h3 {
    margin: 0 0 6px;
    color: #fff;
    font-size: 1.2rem;
    line-height: 1.3;
  }

  .sedar-card-body p {
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.84rem;
    line-height: 1.65;
    max-width: 620px;
  }

  .sedar-card-cta {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .sedar-card:hover .sedar-card-cta,
  .sedar-card:focus-visible .sedar-card-cta {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.32);
  }

  .sedar-card-cta-icon {
    font-size: 1rem;
    color: var(--copper-light);
  }

  @media (max-width: 768px) {
    .sedar-card {
      gap: 18px;
      padding: 22px;
    }
  }
</style>
