---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

const news = (await getCollection("news"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});

const dayNumber = (date: Date) => date.getDate();
const monthLabel = (date: Date) =>
  date.toLocaleDateString("en-US", { month: "short" }).toUpperCase();

const tagClass = (category: string) => {
  if (category === "Press Release") return "press";
  if (category === "Technical") return "technical";
  return "update";
};

const filterSlug = (category: string) =>
  category.toLowerCase().replace(/\s+/g, "-");

const groupedByYear = news.reduce<Record<number, typeof news>>((acc, item) => {
  const year = item.data.date.getFullYear();
  (acc[year] ??= []).push(item);
  return acc;
}, {});

const years = Object.keys(groupedByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<BaseLayout title="News - Argentina Metals Corp.">
  <section class="page-hero page-hero--split page-hero--news">
    <div class="wrap">
      <div class="page-hero-text">
        <h1 data-reveal style="--i:0">News</h1>
        <p data-reveal style="--i:1">Press releases, corporate updates, and exploration progress from Argentina Metals.</p>
      </div>
      <aside class="page-hero-subscribe" data-reveal style="--i:2">
        <div class="subscribe-head">
          <span class="subscribe-icon mi" aria-hidden="true">mail_outline</span>
          <h2>Company Newsletter</h2>
        </div>
        <form class="newsletter-form" name="newsletter" method="post" data-netlify="true">
          <input type="hidden" name="form-name" value="newsletter" />
          <label class="sr-only" for="newsletter-email">Email address</label>
          <input
            id="newsletter-email"
            class="form-input"
            type="email"
            name="email"
            placeholder="you@email.com"
            required
          />
          <button class="button copper-grad" type="submit">
            Subscribe
            <span class="mi" aria-hidden="true">arrow_forward</span>
          </button>
        </form>
      </aside>
    </div>
  </section>
  <section class="content-band">
    <div class="wrap">
      <div class="filter-row" role="tablist" aria-label="News categories">
        <button class="filter active" type="button" data-filter="all">All</button>
        <button class="filter" type="button" data-filter="press-release">Press Releases</button>
        <button class="filter" type="button" data-filter="corporate-update">Corporate Updates</button>
        <button class="filter" type="button" data-filter="technical">Technical</button>
      </div>

      <div class="news-list">
        {years.map((year) => (
          <section class="news-year" data-year={year}>
            <h2 class="news-year-title">{year}</h2>
            <div class="news-rows">
              {groupedByYear[year].map((item) => (
                <a
                  class="news-row"
                  href={`/news/${item.id}`}
                  data-category={filterSlug(item.data.category)}
                >
                  <div class="news-row-date" aria-hidden="true">
                    <span class="news-row-day">{dayNumber(item.data.date)}</span>
                    <span class="news-row-month">{monthLabel(item.data.date)}</span>
                  </div>
                  <div class="news-row-body">
                    <span class:list={["tag", tagClass(item.data.category)]}>{item.data.category}</span>
                    <h3>{item.data.title}</h3>
                    <p>{item.data.excerpt}</p>
                    <span class="news-row-cta">
                      Read article
                      <span class="mi" aria-hidden="true">arrow_forward</span>
                    </span>
                  </div>
                  <time class="sr-only" datetime={item.data.date.toISOString()}>{formatDate(item.data.date)}</time>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>

      <p class="news-empty" hidden>No items in this category.</p>

      <nav class="news-pagination" aria-label="News pagination" hidden>
        <button class="pagination-btn prev" type="button" aria-label="Previous page" disabled>
          <span class="mi" aria-hidden="true">chevron_left</span>
        </button>
        <span class="pagination-info">
          <span class="current-page">1</span> / <span class="total-pages">1</span>
        </span>
        <button class="pagination-btn next" type="button" aria-label="Next page">
          <span class="mi" aria-hidden="true">chevron_right</span>
        </button>
      </nav>
    </div>
  </section>

  <style>
    .news-list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--g100);
      margin-bottom: 48px;
    }

    .page-hero-subscribe {
      justify-self: end;
      width: 100%;
      max-width: 420px;
      padding: 32px;
      border: 1px solid var(--g100);
      border-radius: var(--r-xl);
      background: var(--white);
      box-shadow: var(--s-sm);
      transition: box-shadow 220ms var(--ease), transform 220ms var(--ease);
    }

    .page-hero-subscribe:hover {
      box-shadow: var(--s-md);
    }

    .subscribe-head {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 18px;
    }

    .subscribe-icon {
      display: inline-grid;
      place-items: center;
      width: 32px;
      height: 32px;
      border-radius: var(--r-md);
      background: var(--copper-wash);
      color: var(--copper-dark);
      font-size: 1.05rem;
    }

    .page-hero-subscribe h2 {
      margin: 0;
      color: var(--g900);
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .page-hero-subscribe .newsletter-form {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .page-hero-subscribe .form-input {
      width: 100%;
    }

    .page-hero-subscribe .button.copper-grad {
      width: 100%;
      padding: 13px 22px;
    }

    .page-hero-subscribe .button.copper-grad .mi {
      font-size: 1.05rem;
      transition: transform 220ms var(--ease);
    }

    .page-hero-subscribe .button.copper-grad:hover .mi {
      transform: translateX(3px);
    }

    @media (max-width: 960px) {
      .page-hero-subscribe {
        justify-self: stretch;
        max-width: none;
      }
    }

    .news-year {
      display: grid;
      grid-template-columns: 120px minmax(0, 1fr);
      gap: 32px;
      align-items: start;
    }

    .news-year-title {
      position: sticky;
      top: calc(var(--header-h) - 28px);
      margin: 0;
      padding-top: 28px;
      color: var(--g400);
      font-family: var(--font-display, inherit);
      font-size: 2.4rem;
      font-weight: 300;
      letter-spacing: -0.03em;
      line-height: 1;
    }

    .news-rows {
      display: flex;
      flex-direction: column;
      max-width: 700px;
    }

    .news-row {
      position: relative;
      display: grid;
      grid-template-columns: 68px minmax(0, 1fr);
      gap: 32px;
      align-items: start;
      padding: 28px 0 28px 20px;
      border-bottom: 1px solid var(--g100);
      color: inherit;
      text-decoration: none;
      transition: padding-left 260ms var(--ease);
    }

    .news-row::before {
      content: "";
      position: absolute;
      left: 0;
      top: 28px;
      bottom: 28px;
      width: 2px;
      background: var(--copper-dark);
      transform: scaleY(0);
      transform-origin: top;
      transition: transform 260ms var(--ease);
    }

    .news-row:hover {
      padding-left: 28px;
    }

    .news-row:hover::before {
      transform: scaleY(1);
    }

    .news-row-date {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      color: var(--g900);
      line-height: 1;
    }

    .news-row-day {
      font-size: 2.4rem;
      font-weight: 300;
      letter-spacing: -0.03em;
      color: var(--g900);
    }

    .news-row-month {
      margin-top: 6px;
      color: var(--g400);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
    }

    .news-row-body {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .news-row-body .tag {
      margin-bottom: 2px;
    }

    .news-row-body h3 {
      margin: 0;
      max-width: 60ch;
      color: var(--g900);
      font-size: 1.22rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      line-height: 1.35;
      transition: color 220ms var(--ease);
    }

    .news-row:hover h3 {
      color: var(--copper-dark);
    }

    .news-row-body p {
      margin: 0;
      max-width: 62ch;
      color: var(--g500);
      font-size: 0.9rem;
      line-height: 1.7;
    }

    .news-row-cta {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 4px;
      color: var(--copper-dark);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      opacity: 0;
      transform: translateY(-4px);
      transition: opacity 240ms var(--ease), transform 240ms var(--ease);
    }

    .news-row-cta .mi {
      font-size: 1rem;
      transition: transform 220ms var(--ease);
    }

    .news-row:hover .news-row-cta {
      opacity: 1;
      transform: translateY(0);
    }

    .news-row:hover .news-row-cta .mi {
      transform: translateX(4px);
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .news-row.hidden,
    .news-year.hidden {
      display: none;
    }

    .news-empty {
      margin: 24px 0 0;
      color: var(--g500);
      font-size: 0.9rem;
    }

    .news-pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 18px;
      margin-top: 40px;
    }

    .news-pagination .pagination-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      padding: 0;
      border: 1px solid var(--g100);
      border-radius: var(--radius);
      background: transparent;
      color: var(--g900);
      cursor: pointer;
      transition: background-color 180ms var(--ease), border-color 180ms var(--ease), color 180ms var(--ease);
    }

    .news-pagination .pagination-btn:hover:not(:disabled) {
      border-color: var(--copper-dark);
      color: var(--copper-dark);
    }

    .news-pagination .pagination-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .news-pagination .pagination-info {
      color: var(--g500);
      font-size: 0.82rem;
      letter-spacing: 0.02em;
    }

    .news-pagination .current-page,
    .news-pagination .total-pages {
      color: var(--g900);
      font-weight: 700;
    }

    @media (max-width: 860px) {
      .news-year {
        grid-template-columns: 1fr;
        gap: 18px;
      }

      .news-year-title {
        position: static;
        padding-top: 0;
        font-size: 1.6rem;
      }
    }

    @media (max-width: 768px) {
      .news-row {
        grid-template-columns: 56px minmax(0, 1fr);
        gap: 18px;
        padding-left: 14px;
      }

      .news-row-day {
        font-size: 2rem;
      }

      .news-row-month {
        font-size: 0.64rem;
      }
    }

    @media (max-width: 560px) {
      .news-row {
        grid-template-columns: 1fr;
        gap: 14px;
        padding: 22px 0 22px 16px;
      }

      .news-row:hover {
        padding-left: 22px;
      }

      .news-row::before {
        top: 22px;
        bottom: 22px;
      }

      .news-row-date {
        flex-direction: row;
        align-items: baseline;
        gap: 10px;
      }

      .news-row-day {
        font-size: 1.5rem;
      }

      .news-row-body h3 {
        font-size: 1.08rem;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const buttons = document.querySelectorAll(".filter[data-filter]");
      const rows = document.querySelectorAll(".news-row[data-category]");
      const years = document.querySelectorAll(".news-year");
      const empty = document.querySelector(".news-empty");
      const pagination = document.querySelector(".news-pagination");
      const prevBtn = pagination?.querySelector(".pagination-btn.prev");
      const nextBtn = pagination?.querySelector(".pagination-btn.next");
      const currentPageEl = pagination?.querySelector(".current-page");
      const totalPagesEl = pagination?.querySelector(".total-pages");
      const newsList = document.querySelector(".news-list");

      if (!buttons.length || !rows.length) return;

      const perPage = 20;
      let currentFilter = "all";
      let currentPage = 1;

      const matchesFilter = (row, filter) => {
        const cat = row.getAttribute("data-category");
        return filter === "all" || cat === filter;
      };

      const render = () => {
        const matches = [...rows].filter((r) => matchesFilter(r, currentFilter));
        const totalPages = Math.max(1, Math.ceil(matches.length / perPage));
        if (currentPage > totalPages) currentPage = totalPages;

        const start = (currentPage - 1) * perPage;
        const end = start + perPage;
        const visibleSet = new Set(matches.slice(start, end));

        rows.forEach((row) => {
          row.classList.toggle("hidden", !visibleSet.has(row));
        });

        years.forEach((year) => {
          const any = year.querySelectorAll(".news-row:not(.hidden)").length > 0;
          year.classList.toggle("hidden", !any);
        });

        if (empty) empty.hidden = matches.length > 0;

        if (pagination) {
          pagination.hidden = matches.length <= perPage;
          if (currentPageEl) currentPageEl.textContent = String(currentPage);
          if (totalPagesEl) totalPagesEl.textContent = String(totalPages);
          if (prevBtn) prevBtn.disabled = currentPage <= 1;
          if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
        }
      };

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          buttons.forEach((b) => b.classList.toggle("active", b === btn));
          currentFilter = btn.getAttribute("data-filter");
          currentPage = 1;
          render();
        });
      });

      const goToPage = (page) => {
        currentPage = page;
        render();
        newsList?.scrollIntoView({ behavior: "smooth", block: "start" });
      };

      prevBtn?.addEventListener("click", () => {
        if (currentPage > 1) goToPage(currentPage - 1);
      });

      nextBtn?.addEventListener("click", () => {
        const matches = [...rows].filter((r) => matchesFilter(r, currentFilter));
        const totalPages = Math.max(1, Math.ceil(matches.length / perPage));
        if (currentPage < totalPages) goToPage(currentPage + 1);
      });

      render();
    })();
  </script>
</BaseLayout>
