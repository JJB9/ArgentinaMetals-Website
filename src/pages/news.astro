---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/PageHeader.astro";

const news = (await getCollection("news"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const [featured, ...otherNews] = news;
const recentNews = otherNews.slice(0, 3);
const archiveNews = otherNews.slice(3);

const formatDate = (date: Date) => date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});

const tagClass = (category: string) => {
  if (category === "Press Release") return "press";
  if (category === "Technical") return "technical";
  return "update";
};

const filterSlug = (category: string) =>
  category.toLowerCase().replace(/\s+/g, "-");

const fallbackImage = "/assets/images/rock-quarry-geology.jpg";
---

<BaseLayout title="News - Argentina Metals Corp.">
  <PageHeader
    title="News"
    text="Press releases, corporate updates, and exploration progress from Argentina Metals."
  />
  <section class="content-band">
    <div class="wrap">
      <div class="filter-row" role="tablist" aria-label="News categories">
        <button class="filter active" type="button" data-filter="all">All</button>
        <button class="filter" type="button" data-filter="press-release">Press Releases</button>
        <button class="filter" type="button" data-filter="corporate-update">Corporate Updates</button>
        <button class="filter" type="button" data-filter="technical">Technical</button>
      </div>

      {featured && (
        <a class="news-link featured-news-link" href={`/news/${featured.id}`} data-category={filterSlug(featured.data.category)}>
          <article class="featured-news">
            <div class="split-image">
              <img
                src={featured.data.image ?? fallbackImage}
                alt={featured.data.imageAlt ?? featured.data.title}
                loading="lazy"
              />
            </div>
            <div>
              <span class:list={["tag", tagClass(featured.data.category)]}>{featured.data.category}</span>
              <h2>{featured.data.title}</h2>
              <p>{featured.data.excerpt}</p>
              <div class="post-meta">
                <time datetime={featured.data.date.toISOString()}>
                  <span class="mi" aria-hidden="true">calendar_today</span>
                  {formatDate(featured.data.date)}
                </time>
                {featured.data.readTime && (
                  <span class="post-read-time">
                    <span class="mi" aria-hidden="true">schedule</span>
                    {featured.data.readTime}
                  </span>
                )}
              </div>
            </div>
          </article>
        </a>
      )}

      <div class="news-grid spaced">
        {recentNews.map((item) => (
          <a class="news-link" href={`/news/${item.id}`} data-category={filterSlug(item.data.category)}>
            <article class="news-card">
              {item.data.image && (
                <div class="news-card-img">
                  <img src={item.data.image} alt={item.data.imageAlt ?? item.data.title} loading="lazy" />
                </div>
              )}
              <div class="news-card-body">
                <span class:list={["tag", tagClass(item.data.category)]}>{item.data.category}</span>
                <h3>{item.data.title}</h3>
                <p>{item.data.excerpt}</p>
                <time datetime={item.data.date.toISOString()}>{formatDate(item.data.date)}</time>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  {archiveNews.length > 0 && (
    <section class="section soft">
      <div class="wrap">
        <div class="section-header">
          <div>
            <h2 class="section-title">Previous Releases</h2>
            <p class="section-desc">Earlier corporate milestones and exploration updates.</p>
          </div>
        </div>

        <div class="archive-list">
          {archiveNews.map((item) => (
            <a class="news-link archive-link" href={`/news/${item.id}`} data-category={filterSlug(item.data.category)}>
              <article class="archive-item">
                <time datetime={item.data.date.toISOString()}>{formatDate(item.data.date)}</time>
                <div>
                  <h3>{item.data.title}</h3>
                  <p>{item.data.excerpt}</p>
                </div>
                <span class="mi" aria-hidden="true">arrow_forward</span>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="wrap">
      <div class="newsletter">
        <div>
          <h2>Company Newsletter</h2>
          <p>Sign up to receive periodic corporate milestones and exploration progress from Argentina Metals.</p>
        </div>
        <form class="newsletter-form" name="newsletter" method="post" data-netlify="true">
          <input type="hidden" name="form-name" value="newsletter" />
          <input class="form-input" type="email" name="email" placeholder="Your email address" aria-label="Email address" />
          <button class="button primary" type="submit">Subscribe</button>
        </form>
      </div>
    </div>
  </section>

  <style>
    .news-link {
      display: block;
      color: inherit;
      text-decoration: none;
    }

    .featured-news-link {
      margin-bottom: 30px;
    }

    .featured-news-link .featured-news {
      margin-bottom: 0;
    }

    .archive-link + .archive-link {
      margin-top: 0;
    }
  </style>

  <script is:inline>
    (() => {
      const buttons = document.querySelectorAll(".filter[data-filter]");
      const items = document.querySelectorAll("[data-category]");
      if (!buttons.length || !items.length) return;

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const filter = btn.getAttribute("data-filter");
          buttons.forEach((b) => b.classList.toggle("active", b === btn));
          items.forEach((el) => {
            const match = filter === "all" || el.getAttribute("data-category") === filter;
            el.style.display = match ? "" : "none";
          });
        });
      });
    })();
  </script>
</BaseLayout>
