---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/PageHeader.astro";

const news = (await getCollection("news"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});

const tagClass = (category: string) => {
  if (category === "Press Release") return "press";
  if (category === "Technical") return "technical";
  return "update";
};

const filterSlug = (category: string) =>
  category.toLowerCase().replace(/\s+/g, "-");

const fallbackImage = "/assets/images/rock-quarry-geology.jpg";
---

<BaseLayout title="News - Argentina Metals Corp.">
  <PageHeader
    title="News"
    text="Press releases, corporate updates, and exploration progress from Argentina Metals."
  />
  <section class="content-band">
    <div class="wrap">
      <div class="filter-row" role="tablist" aria-label="News categories">
        <button class="filter active" type="button" data-filter="all">All</button>
        <button class="filter" type="button" data-filter="press-release">Press Releases</button>
        <button class="filter" type="button" data-filter="corporate-update">Corporate Updates</button>
        <button class="filter" type="button" data-filter="technical">Technical</button>
      </div>

      <div class="news-grid cards-grid">
        {news.map((item) => (
          <a class="news-link" href={`/news/${item.id}`} data-category={filterSlug(item.data.category)} data-order={news.indexOf(item)}>
            <article class="news-card">
              {item.data.image && (
                <div class="news-card-img">
                  <img src={item.data.image} alt={item.data.imageAlt ?? item.data.title} loading="lazy" />
                </div>
              )}
              <div class="news-card-body">
                <span class:list={["tag", tagClass(item.data.category)]}>{item.data.category}</span>
                <h3>{item.data.title}</h3>
                <p>{item.data.excerpt}</p>
                <time datetime={item.data.date.toISOString()}>{formatDate(item.data.date)}</time>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  {news.length > 6 && (
    <section class="section soft">
      <div class="wrap">
        <div class="section-header">
          <div>
            <h2 class="section-title">Previous Releases</h2>
            <p class="section-desc">Earlier corporate milestones and exploration updates.</p>
          </div>
        </div>

        <div class="archive-list">
          {news.slice(6).map((item, index) => (
            <a class="news-link archive-link" href={`/news/${item.id}`} data-category={filterSlug(item.data.category)} data-archive-index={index}>
              <article class="archive-item">
                <time datetime={item.data.date.toISOString()}>{formatDate(item.data.date)}</time>
                <div>
                  <h3>{item.data.title}</h3>
                  <p>{item.data.excerpt}</p>
                </div>
                <span class="mi" aria-hidden="true">arrow_forward</span>
              </article>
            </a>
          ))}
        </div>

        {news.slice(6).length > 10 && (
          <div class="pagination">
            <button class="pagination-btn prev" type="button" aria-label="Previous page" disabled>
              <span class="mi" aria-hidden="true">chevron_left</span>
            </button>
            <span class="pagination-info">
              <span class="current-page">1</span> / <span class="total-pages">1</span>
            </span>
            <button class="pagination-btn next" type="button" aria-label="Next page">
              <span class="mi" aria-hidden="true">chevron_right</span>
            </button>
          </div>
        )}
      </div>
    </section>
  )}

  <section class="section">
    <div class="wrap">
      <div class="newsletter">
        <div>
          <h2>Company Newsletter</h2>
          <p>Sign up to receive periodic corporate milestones and exploration progress from Argentina Metals.</p>
        </div>
        <form class="newsletter-form" name="newsletter" method="post" data-netlify="true">
          <input type="hidden" name="form-name" value="newsletter" />
          <input class="form-input" type="email" name="email" placeholder="Your email address" aria-label="Email address" />
          <button class="button primary" type="submit">Subscribe</button>
        </form>
      </div>
    </div>
  </section>

  <style>
    .news-link {
      display: block;
      color: inherit;
      text-decoration: none;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-bottom: 40px;
    }

    @media (max-width: 768px) {
      .cards-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 480px) {
      .cards-grid {
        grid-template-columns: 1fr;
      }
    }

    .archive-link + .archive-link {
      margin-top: 0;
    }

    .archive-link.hidden {
      display: none !important;
    }

    .pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-top: 32px;
      padding-top: 32px;
      border-top: 1px solid var(--color-sand);
    }

    .pagination-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      padding: 0;
      border: 1px solid var(--color-sand);
      background: transparent;
      color: inherit;
      cursor: pointer;
      border-radius: 4px;
      transition: all 0.2s ease;
    }

    .pagination-btn:hover:not(:disabled) {
      background: var(--color-sand);
      border-color: var(--color-stone);
    }

    .pagination-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .pagination-info {
      font-size: 14px;
      color: var(--color-stone);
    }

    .current-page,
    .total-pages {
      font-weight: 600;
    }
  </style>

  <script is:inline>
    (() => {
      const buttons = document.querySelectorAll(".filter[data-filter]");
      const cardItems = document.querySelectorAll(".cards-grid .news-link");
      const archiveItems = document.querySelectorAll(".archive-list .news-link");
      const paginationPrev = document.querySelector(".pagination-btn.prev");
      const paginationNext = document.querySelector(".pagination-btn.next");
      const currentPageSpan = document.querySelector(".current-page");
      const totalPagesSpan = document.querySelector(".total-pages");

      if (!buttons.length || !cardItems.length) return;

      let currentPage = 0;
      let currentFilter = "all";
      const itemsPerPage = 10;

      const getFilteredArchiveItems = (filter) => {
        return Array.from(archiveItems).filter((el) => {
          const cat = el.getAttribute("data-category");
          return filter === "all" || cat === filter;
        });
      };

      const updateArchivePagination = () => {
        const filteredItems = getFilteredArchiveItems(currentFilter);
        const totalPages = Math.ceil(filteredItems.length / itemsPerPage);

        filteredItems.forEach((el, index) => {
          const pageIndex = Math.floor(index / itemsPerPage);
          el.classList.toggle("hidden", pageIndex !== currentPage);
        });

        if (currentPageSpan && totalPagesSpan) {
          currentPageSpan.textContent = currentPage + 1;
          totalPagesSpan.textContent = Math.max(1, totalPages);
        }

        if (paginationPrev) paginationPrev.disabled = currentPage === 0;
        if (paginationNext) paginationNext.disabled = currentPage >= totalPages - 1;
      };

      const updateDisplay = (filter) => {
        const allItems = Array.from(cardItems);
        let visibleCount = 0;

        // Show/hide cards based on filter (max 6)
        allItems.forEach((el) => {
          const cat = el.getAttribute("data-category");
          const matches = filter === "all" || cat === filter;

          if (matches && visibleCount < 6) {
            el.style.display = "";
            visibleCount++;
          } else {
            el.style.display = "none";
          }
        });

        currentFilter = filter;
        currentPage = 0;
        updateArchivePagination();
      };

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const filter = btn.getAttribute("data-filter");
          buttons.forEach((b) => b.classList.toggle("active", b === btn));
          updateDisplay(filter);
        });
      });

      if (paginationPrev) {
        paginationPrev.addEventListener("click", () => {
          if (currentPage > 0) {
            currentPage--;
            updateArchivePagination();
            document.querySelector(".pagination")?.scrollIntoView({ behavior: "smooth" });
          }
        });
      }

      if (paginationNext) {
        paginationNext.addEventListener("click", () => {
          const filteredItems = getFilteredArchiveItems(currentFilter);
          const totalPages = Math.ceil(filteredItems.length / itemsPerPage);
          if (currentPage < totalPages - 1) {
            currentPage++;
            updateArchivePagination();
            document.querySelector(".pagination")?.scrollIntoView({ behavior: "smooth" });
          }
        });
      }

      // Initialize with "all" filter
      updateDisplay("all");
    })();
  </script>
</BaseLayout>
