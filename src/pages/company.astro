---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/PageHeader.astro";
---

<BaseLayout title="Company - Argentina Metals Corp.">
  <PageHeader
    eyebrow="Company"
    title="Argentina Metals Corp."
    text="A mineral exploration company positioned as a pure-play vehicle for the geological extension of Chile's copper corridor into Argentina."
  />
  <section class="content-band">
    <div class="wrap content-grid">
      <article class="card"><h3>Geological Symmetry</h3><p>The same Andean porphyry belt that produced many of the world's largest copper mines continues into Argentina.</p></article>
      <article class="card"><h3>Policy Tailwind</h3><p>Reforms, permitting momentum, and major-company commitments are improving the operating backdrop for exploration.</p></article>
      <article class="card"><h3>Capital Alignment</h3><p>A focused structure and significant insider ownership are designed for maximum leverage to discovery.</p></article>
    </div>
  </section>
</BaseLayout>
