---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/PageHeader.astro";
import AndesHero from "../components/islands/AndesHero";
import { projects } from "../data/projects";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Projects - Argentina Metals Corp.">
  <PageHeader
    title="Projects"
    text="Our exploration portfolio spans 146,728 hectares across the Western Malargue Mining District — one of Argentina's most prospective copper-gold corridors."
    stats={[
      { value: "146,728 ha", label: "Total Land Package" },
      { value: "26", label: "Project Areas" },
      { value: "100+", label: "GIS Targets" }
    ]}
  />

  <div class="hero-media" data-reveal>
    <div class="hero-media-frame hero-media-frame--map">
      <AndesHero client:visible />
    </div>
  </div>

  <section class="content-band content-band--spacious">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Flagship Project</h2>
          <p class="section-desc">Our most advanced target has two distinct mineralization styles confirmed by surface geochemistry and magnetometric surveys.</p>
        </div>
      </div>

      <a class="project-flagship" id="las-estrellas" href="/projects/las-estrellas">
        <div class="split-image">
          <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1400&q=80" alt="Las Estrellas project area in the Andes" loading="lazy" />
        </div>
        <div class="project-flagship-body">
          <span class="tag press">Flagship</span>
          <h2>Las Estrellas</h2>
          <p>Manto-type copper oxides in the Rio Damas Formation and porphyry copper-gold signatures in the Huincan Formation. Surface sampling returned up to 9,978 ppm Cu. Magnetometric survey complete with drill-ready targets defined at 50-150 m depth.</p>
          <div class="detail-list">
            <span><span class="mi" aria-hidden="true">layers</span> Manto-type + Porphyry Cu-Au</span>
            <span><span class="mi" aria-hidden="true">science</span> 144 rock chips collected</span>
            <span><span class="mi" aria-hidden="true">my_location</span> 1.5 km to KBX drilling</span>
          </div>
          <span class="button primary" style="width:fit-content">View Project Details <span class="mi" aria-hidden="true">arrow_forward</span></span>
        </div>
      </a>
    </div>
  </section>

  <section class="section soft">
    <div class="wrap">
      <div class="section-header">
        <div>
          <h2 class="section-title">Satellite &amp; Exploration Targets</h2>
          <p class="section-desc">Priority targets across the district, each leveraging the same geological corridor that hosts Las Estrellas.</p>
        </div>
      </div>

      <div class="project-grid">
        {projects.map((project, i) => (
          <article class="project-card" data-reveal style={`--i:${i % 3}`}>
            <div class="project-card-img">
              <img src={project.image} alt={project.imageAlt} loading="lazy" />
            </div>
            <div class="project-card-body">
              <span class:list={["tag", { technical: project.tag === "Early-Stage" }]}>{project.tag}</span>
              <h3>{project.title}</h3>
              <p>{project.text}</p>
              <div class="card-meta">
                {project.meta.map(([icon, label]) => (
                  <span>
                    <span class="mi" aria-hidden="true">{icon}</span>
                    {label}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Land Position Summary</h2>
          <p class="section-desc">Consolidated tenure across acquired and staked project areas — with the district-level work already on the ground.</p>
        </div>
      </div>

      <div class="land-summary">
        <article class="land-card land-card--primary" data-reveal style="--i:0">
          <div class="land-hero">
            <span class="land-hero-label">Consolidated Land Package</span>
            <strong class="land-hero-value">146,728<span>ha</span></strong>
            <span class="land-hero-sub">26 project areas across the Western Malargüe corridor</span>
          </div>

          <div class="land-bar" role="img" aria-label="Acquired: 132,155 hectares (90%). Staked: 14,573 hectares (10%).">
            <span class="land-bar-seg land-bar-seg--acquired" style="--pct: 90.07%"></span>
            <span class="land-bar-seg land-bar-seg--staked" style="--pct: 9.93%"></span>
          </div>

          <dl class="land-split">
            <div class="land-split-item">
              <span class="land-swatch land-swatch--acquired" aria-hidden="true"></span>
              <div>
                <dt>Acquired</dt>
                <dd><strong>132,155 ha</strong><span>24 project areas</span></dd>
              </div>
            </div>
            <div class="land-split-item">
              <span class="land-swatch land-swatch--staked" aria-hidden="true"></span>
              <div>
                <dt>Staked</dt>
                <dd><strong>14,573 ha</strong><span>2 project areas</span></dd>
              </div>
            </div>
          </dl>
        </article>

        <article class="land-card land-card--status" data-reveal style="--i:1">
          <h3 class="land-card-title">Project Readiness</h3>
          <ul class="land-checklist">
            <li>
              <span class="land-check" aria-hidden="true"><span class="mi">verified</span></span>
              <div>
                <strong>Clean Title</strong>
                <span>No NSRs or earn-in agreements</span>
              </div>
            </li>
            <li>
              <span class="land-check" aria-hidden="true"><span class="mi">description</span></span>
              <div>
                <strong>NI 43-101 Technical Report</strong>
                <span>Completed</span>
              </div>
            </li>
            <li>
              <span class="land-check" aria-hidden="true"><span class="mi">explore</span></span>
              <div>
                <strong>Mapping, Geophysics &amp; Geochemistry</strong>
                <span>Initial district program completed</span>
              </div>
            </li>
          </ul>
        </article>
      </div>
    </div>
  </section>

</BaseLayout>
