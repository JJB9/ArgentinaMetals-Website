---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/PageHeader.astro";
const base = import.meta.env.BASE_URL;

const projects = [
  {
    tag: "Satellite",
    title: "El Burrero Group",
    text: "Historic copper mining area within the Río Damas Formation. Manto-type stratabound mineralization with high-grade potential at accessible depth.",
    image: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=800&q=80",
    imageAlt: "El Burrero project terrain",
    meta: [["layers", "Manto-type Cu"], ["location_on", "W. Malargüe"]]
  },
  {
    tag: "Satellite",
    title: "Northern Cluster",
    text: "Multiple GIS-defined anomalies across acquired concessions. Structural corridor aligned with regional NW-SE lineaments controlling hydrothermal fluid pathways.",
    image: "https://images.unsplash.com/photo-1519681393784-d120267933ba?auto=format&fit=crop&w=800&q=80",
    imageAlt: "Northern cluster project terrain",
    meta: [["hub", "Structural targets"], ["location_on", "W. Malargüe"]]
  },
  {
    tag: "Satellite",
    title: "Porphyry Corridor",
    text: "Targets defined by GIS modelling, analogous to the El Perdido system currently being drill-tested by Kobrea Exploration to the west.",
    image: "https://images.unsplash.com/photo-1454496522488-7a8e488e8606?auto=format&fit=crop&w=800&q=80",
    imageAlt: "Porphyry corridor terrain",
    meta: [["volcano", "Porphyry model"], ["location_on", "W. Malargüe"]]
  },
  {
    tag: "Early-Stage",
    title: "Southern Extensions",
    text: "Staked ground extending the land package south along strike of known copper-bearing formations. Early-stage reconnaissance confirms prospective geology.",
    image: "https://images.unsplash.com/photo-1486870591958-9b9d0d1dda99?auto=format&fit=crop&w=800&q=80",
    imageAlt: "Southern extensions terrain",
    meta: [["south", "Along-strike"], ["explore", "Reconnaissance"]]
  },
  {
    tag: "Early-Stage",
    title: "Additional Concessions",
    text: "Remaining project areas under GIS evaluation. Priority ranking is based on geochemical signatures, structural positioning, and proximity to confirmed mineralization.",
    image: "https://images.unsplash.com/photo-1542224566-6e85f2e6772f?auto=format&fit=crop&w=800&q=80",
    imageAlt: "Additional concessions terrain",
    meta: [["grid_view", "GIS evaluation"], ["schedule", "Pipeline"]]
  },
  {
    tag: "Early-Stage",
    title: "Western Corridor",
    text: "Acquired concessions along the western margin of the district. Prospective for both manto-type and deeper porphyry-style mineralization.",
    image: "https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=800&q=80",
    imageAlt: "Western corridor terrain",
    meta: [["terrain", "Cu-Au targets"], ["location_on", "W. Malargüe"]]
  }
];

const roadmap = [
  {
    phase: "Phase 01",
    status: "Completed",
    title: "Consolidation & Targeting",
    text: "Land acquisition, historical data compilation, GIS target generation, and initial mapping. 100+ priority targets defined across 26 project areas."
  },
  {
    phase: "Phase 02",
    status: "Current",
    title: "Surface Work & Geophysics",
    text: "Detailed mapping, geochemical sampling, and magnetometric surveys at Las Estrellas. Pre-drill work and additional license acquisition in satellite areas."
  },
  {
    phase: "Phase 03",
    status: "Next",
    title: "Drill Testing",
    text: "Inaugural drill program testing highest-priority targets defined through Phase 2 magnetometric and geochemical anomalies at Las Estrellas."
  }
];
---

<BaseLayout title="Projects - Argentina Metals Corp.">
  <PageHeader
    title="Projects"
    text="Our exploration portfolio spans 146,728 hectares across the Western Malargue Mining District — one of Argentina's most prospective copper-gold corridors."
    image={`${base}assets/images/rock-quarry-geology.jpg`}
    imageAlt="Western Malargue Mining District, Mendoza Province"
    stats={[
      { value: "146,728 ha", label: "Total Land Package" },
      { value: "26", label: "Project Areas" },
      { value: "100+", label: "GIS Targets" }
    ]}
  />
  <section class="content-band">
    <div class="wrap">
      <div class="section-header">
        <div>
          <h2 class="section-title">Flagship Project</h2>
          <p class="section-desc">Our most advanced target has two distinct mineralization styles confirmed by surface geochemistry and magnetometric surveys.</p>
        </div>
      </div>

      <a class="project-flagship" id="las-estrellas" href="/contact">
        <div class="split-image">
          <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1400&q=80" alt="Las Estrellas project area in the Andes" loading="lazy" />
        </div>
        <div class="project-flagship-body">
          <span class="tag press">Flagship</span>
          <h2>Las Estrellas</h2>
          <p>Manto-type copper oxides in the Rio Damas Formation and porphyry copper-gold signatures in the Huincan Formation. Surface sampling returned up to 9,978 ppm Cu. Magnetometric survey complete with drill-ready targets defined at 50-150 m depth.</p>
          <div class="detail-list">
            <span><span class="mi" aria-hidden="true">layers</span> Manto-type + Porphyry Cu-Au</span>
            <span><span class="mi" aria-hidden="true">science</span> 144 rock chips collected</span>
            <span><span class="mi" aria-hidden="true">my_location</span> 1.5 km to KBX drilling</span>
          </div>
          <span class="button primary" style="width:fit-content">View Project Details <span class="mi" aria-hidden="true">arrow_forward</span></span>
        </div>
      </a>
    </div>
  </section>

  <section class="section soft">
    <div class="wrap">
      <div class="section-header">
        <div>
          <h2 class="section-title">Satellite &amp; Exploration Targets</h2>
          <p class="section-desc">Priority targets across the district, each leveraging the same geological corridor that hosts Las Estrellas.</p>
        </div>
      </div>

      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-card">
            <div class="project-card-img">
              <img src={project.image} alt={project.imageAlt} loading="lazy" />
            </div>
            <div class="project-card-body">
              <span class:list={["tag", { technical: project.tag === "Early-Stage" }]}>{project.tag}</span>
              <h3>{project.title}</h3>
              <p>{project.text}</p>
              <div class="card-meta">
                {project.meta.map(([icon, label]) => (
                  <span>
                    <span class="mi" aria-hidden="true">{icon}</span>
                    {label}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-header">
        <div>
          <h2 class="section-title">Land Position Summary</h2>
          <p class="section-desc">Consolidated tenure across acquired and staked project areas.</p>
        </div>
      </div>

      <div class="data-card">
        <table>
          <tbody>
            <tr><th scope="row">Projects Acquired</th><td>24 / 132,155 ha</td></tr>
            <tr><th scope="row">Projects Staked</th><td>2 / 14,573 ha</td></tr>
            <tr class="highlight"><th scope="row">Total Land Package</th><td>146,728 ha</td></tr>
            <tr><th scope="row">Title Status</th><td><span class="chk">Clean / No NSRs or Earn-Ins <span class="mi" aria-hidden="true">check_circle</span></span></td></tr>
            <tr><th scope="row">NI 43-101 Technical Report</th><td>Completed</td></tr>
            <tr><th scope="row">Initial Mapping, Geophysics &amp; Geochemistry</th><td>Completed</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="wrap">
      <div class="section-header">
        <div>
          <h2 class="section-title">Roadmap</h2>
          <p class="section-desc">Three phases from consolidation through discovery. Phase 2 is underway across Las Estrellas and priority satellite targets.</p>
        </div>
      </div>

      <div class="timeline-grid">
        {roadmap.map((item) => (
          <article class="timeline-card">
            <div class="timeline-top"><span>{item.phase}</span><strong>{item.status}</strong></div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="callout">
        <div>
          <span>District Validation / Neighbor Activity</span>
          <h2>Kobrea is drilling El Perdido — 1.5 km from our boundary.</h2>
          <p>Kobrea Exploration (CSE: KBX) is actively drilling the El Perdido porphyry copper-gold-molybdenum target immediately west of Las Estrellas. Their program provides direct third-party validation of the geological model and the district's potential.</p>
        </div>
        <div class="callout-metric">
          <span class="mi" aria-hidden="true">my_location</span>
          <div>
            <div class="sv">1.5 km</div>
            <div class="sl">To KBX Drilling</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
