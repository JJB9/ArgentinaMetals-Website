---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import KpiCounter from "../components/islands/KpiCounter";
import AndesHero from "../components/islands/AndesHero";

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path}`;
const news = (await getCollection("news"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) => date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});

const thesis = [
  {
    title: "Same Geology",
    text: "Argentina shares the high-grade Andean belt with Chile — the world's #1 producer — yet remains chronically underexplored."
  },
  {
    title: "Mining Reset",
    text: "President Milei's pro-business reforms are sparking a structural re-rating of Argentine mining assets across every stage."
  },
  {
    title: "District Scale",
    text: "Amassing 146,000+ hectares across prime districts before the surge in major M&A activity reshapes the region."
  }
];

const mileiItems = [
  ["Capital Controls Lifted", "Free flow of capital incentivizes major foreign direct investment."],
  ["RIGI Implementation", "Large Investment Incentive Regime guarantees tax stability for 30 years."],
  ["Pro-Mining Provincial Stance", "Key provinces like San Juan actively courting developers."]
];

const kpi = [
  ["Global Potential", "#7", "Copper reserve ranking"],
  ["CAPEX Pipeline", "$30B", "Regional investment plans"],
  ["Land Controlled", "146k", "Hectares across prime districts"],
  ["Ownership", "~60%", "Core project interest"]
];
---

<BaseLayout
  title="Argentina Metals Corp. - A Pure-Play on Argentina's Copper Boom"
  description="Argentina Metals Corp. is acquiring district-scale copper exploration assets across Argentina's underexplored Andean copper belts."
>
  <section class="hero">
    <div class="wrap">
      <h1 data-reveal style="--i:0">A Pure-Play on Argentina's <em>Copper Boom</em></h1>
      <p data-reveal style="--i:1">Acquiring premium assets in the world's #7 copper region while the market re-prices the "Milei Effect."</p>
      <div class="hero-actions" data-reveal style="--i:2">
        <a class="button primary" href="#thesis">Explore the Opportunity <span class="mi" aria-hidden="true">arrow_forward</span></a>
        <a class="button secondary" href="/investor">View Investor Deck</a>
      </div>
    </div>
  </section>

  <div class="hero-media" data-reveal style="--i:3">
    <div class="hero-media-frame">
      <video data-parallax autoplay muted loop playsinline src={asset("assets/images/case-video.mp4")}></video>
    </div>
  </div>

  <section class="section" id="thesis">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <span class="section-num">01</span>
        <div>
          <h2 class="section-title">The Thesis</h2>
          <p class="section-desc">Three unshakeable pillars define our approach to the Argentine copper boom — a strategy built on geology, policy, and scale.</p>
        </div>
      </div>

      <div class="card-grid">
        {thesis.map((item, i) => (
          <article class="card" data-reveal style={`--i:${i}`}>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <span class="section-num">02</span>
        <div>
          <h2 class="section-title">From Overlooked to Essential</h2>
          <p class="section-desc">Decades of political instability kept capital out of Argentina, creating a profound valuation gap. That gap is closing fast.</p>
        </div>
      </div>

      <div class="split">
        <div class="split-visual" data-reveal>
          <div class="split-image">
            <img data-parallax src={asset("assets/images/rock-quarry-geology.jpg")} alt="Layered geology in a copper exploration district" loading="lazy" />
          </div>
          <div class="split-badge">
            <strong>Top 10</strong>
            <span>Global Copper Reserve Potential</span>
          </div>
          <div class="policy-card">
            <h3>The Milei Effect</h3>
            <ul>
              {mileiItems.map(([title, desc]) => (
                <li>
                  <span class="mi" aria-hidden="true">check_circle</span>
                  <div><strong>{title}</strong>{desc}</div>
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="split-copy" data-reveal style="--i:1">
          <h2>Re-rating a century of missed opportunity.</h2>
          <p>For decades, political instability kept capital out of Argentina, creating a profound valuation gap compared to its neighbors. The "Milei Effect" is rapidly closing this gap — and the early movers capture the arbitrage.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <span class="section-num">03</span>
        <div>
          <h2 class="section-title">The Electrification Metal</h2>
          <p class="section-desc">The world cannot decarbonize without copper. We are entering a structural deficit driven by unprecedented demand and anemic new supply.</p>
        </div>
      </div>

      <svg width="0" height="0" style="position:absolute" aria-hidden="true">
        <defs>
          <linearGradient id="copperGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#C5642B" />
            <stop offset="50%" stop-color="#D4783F" />
            <stop offset="100%" stop-color="#FDB473" />
          </linearGradient>
        </defs>
      </svg>

      <div class="rings">
        <KpiCounter
          client:visible
          title="New Mines Needed"
          description="Required by 2030 to meet basic energy-transition demand."
          ringOffset={96}
          label="80"
          animateTo={80}
        />
        <KpiCounter
          client:visible
          title="Copper per EV"
          description="Electric vehicles consume multiples of the copper used in ICE vehicles."
          ringOffset={48}
          label="3-4×"
        />
        <KpiCounter
          client:visible
          title="Discovery to Production"
          description="The timeline to bring new supply online is longer than ever."
          ringOffset={170}
          label="16y"
          animateTo={16}
          animateSuffix="y"
        />
        <KpiCounter
          client:visible
          title="Grade Decline"
          description="Existing majors face sustained drops in ore quality across the board."
          ringOffset={345}
          label="−20%"
          animateTo={20}
          animatePrefix="−"
          animateSuffix="%"
        />
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <span class="section-num">04</span>
        <div>
          <h2 class="section-title">The Rocks Don't Know They Crossed a Border</h2>
          <p class="section-desc">The Andes host the world's greatest copper deposits. Chile has mined their side for a century. Argentina's side is virtually untouched.</p>
        </div>
      </div>

      <div class="rocks-layout">
        <div class="rocks-features">
          <article class="feature" data-reveal style="--i:0">
            <h3>Elite prospects at entry-level pricing.</h3>
            <p>Acquiring highly prospective ground in Argentina today costs a fraction of similar ground in Chile — despite sharing the same geological belt, the same intrusive history, and the same copper-gold endowment.</p>
            <a class="feature-link" href="/projects">Read the technical report <span class="mi" aria-hidden="true">arrow_forward</span></a>
            <div class="feature-metrics">
              <div><strong>#7</strong><span>Global Copper Rank</span></div>
              <div><strong>146k+</strong><span>Hectares Controlled</span></div>
            </div>
          </article>

          <article class="feature alt" data-reveal style="--i:1">
            <h3>One of the largest private packages in the region.</h3>
            <p>We control district-scale ground across the most prospective belts in San Juan and Catamarca, giving us multi-decade exploration runway before the rush begins in earnest.</p>
            <a class="feature-link" href="/projects">Explore the projects <span class="mi" aria-hidden="true">arrow_forward</span></a>
            <div class="feature-metrics">
              <div><strong>$30B+</strong><span>Investment Pipeline</span></div>
              <div><strong>~60%</strong><span>Core Ownership</span></div>
            </div>
          </article>
        </div>

        <div class="rocks-map" data-reveal style="--i:2">
          <AndesHero client:visible />
        </div>
      </div>
    </div>
  </section>

  <section class="section compact-top">
    <div class="wrap">
      <div class="stats-grid" aria-label="Company highlights">
        {kpi.map(([lbl, val, caption], i) => (
          <div class="stat" data-reveal style={`--i:${i}`}><span>{lbl}</span><strong>{val}</strong><p>{caption}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <span class="section-num">05</span>
        <div>
          <h2 class="section-title">Latest News</h2>
          <p class="section-desc">Recent press releases and corporate updates from Argentina Metals.</p>
        </div>
      </div>

      <div class="news-grid">
        {news.map((item, i) => (
          <a class="news-card" href="/news" data-reveal style={`--i:${i}`}>
            {item.data.image && (
              <div class="news-card-img">
                <img src={item.data.image} alt={item.data.imageAlt ?? item.data.title} loading="lazy" />
              </div>
            )}
            <div class="news-card-body">
              <span class:list={["tag", { press: item.data.category === "Press Release", technical: item.data.category === "Technical" }]}>{item.data.category}</span>
              <h3>{item.data.title}</h3>
              <p>{item.data.excerpt}</p>
              <time datetime={item.data.date.toISOString()}>{formatDate(item.data.date)}</time>
            </div>
          </a>
        ))}
      </div>

      <a class="feature-link news-all-link" href="/news">View All News <span class="mi" aria-hidden="true">arrow_forward</span></a>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="callout" data-reveal>
        <div>
          <span>Investor Access</span>
          <h2>Position yourself before the market catches up.</h2>
          <p>Explore the investor deck or get in touch to learn more about the Argentina copper opportunity.</p>
        </div>
        <a class="button primary" href="/investor">View Investor Materials</a>
      </div>
    </div>
  </section>
</BaseLayout>
