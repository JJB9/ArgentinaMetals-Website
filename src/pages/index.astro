---
import BaseLayout from "@layouts/BaseLayout.astro";
import AndesHero from "../components/islands/AndesHero";
import MapLegend from "../components/MapLegend.astro";

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path}`;

const mileiItems = [
  ["Capital Controls Lifted", "Free flow of capital, opening the door to major foreign direct investment."],
  ["RIGI Implementation", "Régimen de Incentivo para Grandes Inversiones. Guarantees 30 years of tax stability for qualifying mining projects."],
  ["Pro-Mining Provincial Stance", "Mendoza and neighbouring provinces are actively courting explorers and developers."]
];

const copperSeries: Array<{ year: number; value: number }> = [
  { year: 1850, value: 0.1 },
  { year: 1900, value: 0.5 },
  { year: 1910, value: 0.9 },
  { year: 1920, value: 1.0 },
  { year: 1930, value: 1.6 },
  { year: 1940, value: 2.0 },
  { year: 1950, value: 2.4 },
  { year: 1960, value: 3.9 },
  { year: 1970, value: 5.9 },
  { year: 1980, value: 7.2 },
  { year: 1990, value: 9.2 },
  { year: 2000, value: 13.3 },
  { year: 2010, value: 16.1 },
  { year: 2020, value: 20.6 },
  { year: 2025, value: 23.2 }
];

const chartW = 1200;
const chartH = 600;
const padT = 40;
const padR = 28;
const padB = 100;
const padL = 64;
const plotW = chartW - padL - padR;
const plotH = chartH - padT - padB;
const xMin = 1850;
const xMax = 2025;
const yMax = 25;
const yTicks = [0, 5, 10, 15, 20, 25];

const px = (year: number) => padL + ((year - xMin) / (xMax - xMin)) * plotW;
const py = (value: number) => padT + plotH - (value / yMax) * plotH;
const fmt = (n: number) => n.toFixed(2);

const points = copperSeries.map((d) => ({ ...d, x: px(d.year), y: py(d.value) }));
const linePath = points.map((p, i) => `${i === 0 ? "M" : "L"}${fmt(p.x)},${fmt(p.y)}`).join(" ");
const areaPath = `${linePath} L${fmt(points[points.length - 1].x)},${fmt(py(0))} L${fmt(points[0].x)},${fmt(py(0))} Z`;
const lastIdx = points.length - 1;

const cumulativeLengths = points.reduce<number[]>((acc, p, i) => {
  const last = i === 0 ? 0 : acc[i - 1];
  const seg = i === 0 ? 0 : Math.hypot(p.x - points[i - 1].x, p.y - points[i - 1].y);
  acc.push(last + seg);
  return acc;
}, []);
const totalPathLength = cumulativeLengths[cumulativeLengths.length - 1] || 1;
const pointProgress = cumulativeLengths.map((c) => c / totalPathLength);
---

<BaseLayout
  title="Investing in Argentina and Its Emerging Copper Boom - Argentina Metals"
>
  <link rel="preload" as="image" href={asset("images/brand/preview-thumbnail.webp")} fetchpriority="high" slot="head" />
  <script is:inline slot="head" defer src="https://cdn.jsdelivr.net/npm/@mux/mux-player"></script>

  <div class="hero-media hero-media--lead" data-reveal style="--i:0">
    <div class="hero-media-frame" id="hero-media-frame">
      <mux-player
        id="hero-mux-player"
        data-parallax
        playback-id={import.meta.env.PUBLIC_MUX_HERO_PLAYBACK_ID}
        metadata-video-title="Argentina Metals, hero image clip"
        poster={asset("images/brand/preview-thumbnail.webp")}
        stream-type="on-demand"
        loop
        playsinline
        preload="metadata"
      ></mux-player>
    </div>
  </div>

  <section class="hero hero--after-media">
    <div class="wrap">
      <h1 data-reveal style="--i:1">Investing in Argentina and Its Emerging <em>Copper Boom</em></h1>
      <div class="hero-actions" data-reveal style="--i:2">
        <a class="button primary" href="/projects">Explore the Opportunity <span class="mi" aria-hidden="true">arrow_forward</span></a>
        <a class="button secondary" href="/investor#docs">View Corporate Presentation</a>
      </div>
    </div>
  </section>

  <section class="section" id="thesis">
    <div class="wrap">
      <div class="section-spread section-spread--wide-evidence">
        <header class="section-intro" data-reveal>
          <h2 class="section-title">Copper is a Blockbuster</h2>
          <p class="section-lead">Copper needs no marketing. When the world economy grows, so does copper demand, and the world economy has grown for 150 years straight. Electrification and data centers now add a second, durable layer of demand on top.</p>
        </header>

        <div class="section-evidence" data-reveal style="--i:1">
          <figure class="copper-chart copper-chart--svg copper-chart--compact">
            <svg
              viewBox={`0 0 ${chartW} ${chartH}`}
              role="img"
              aria-labelledby="copper-svg-title copper-svg-desc"
              preserveAspectRatio="xMidYMid meet"
            >
              <title id="copper-svg-title">Global copper production, 1850–2025</title>
              <desc id="copper-svg-desc">Line chart of global copper production rising from 0.1 million metric tons in 1850 to 23.2 million metric tons in 2025.</desc>

              <defs>
                <linearGradient id="copper-area-fill" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#d4783f" stop-opacity="0.28" />
                  <stop offset="100%" stop-color="#d4783f" stop-opacity="0" />
                </linearGradient>
                <clipPath id="copper-area-clip" clipPathUnits="userSpaceOnUse">
                  <rect class="area-clip-rect" x={padL} y={padT} width={plotW} height={plotH} />
                </clipPath>
              </defs>

              {yTicks.map((t) => (
                <g class="grid-row">
                  <line
                    class="grid-line"
                    x1={padL}
                    x2={chartW - padR}
                    y1={py(t)}
                    y2={py(t)}
                  />
                  <text class="axis-label y-label" x={padL - 12} y={py(t) + 4}>{t}</text>
                </g>
              ))}

              <line
                class="axis-line"
                x1={padL}
                x2={chartW - padR}
                y1={py(0)}
                y2={py(0)}
              />

              <path class="data-area" d={areaPath} clip-path="url(#copper-area-clip)" />
              <path class="data-line" d={linePath} pathLength="1" />

              {points.map((p, i) => {
                const isEnd = i === lastIdx;
                return (
                  <g class="data-point" style={`--reveal-progress: ${pointProgress[i].toFixed(4)}`}>
                    <circle
                      class={isEnd ? "data-marker data-marker--end" : "data-marker"}
                      cx={p.x}
                      cy={p.y}
                      r={isEnd ? 5.5 : 4}
                    />
                    <text
                      class={isEnd ? "data-value data-value--end" : "data-value"}
                      x={p.x}
                      y={p.y - 12}
                    >
                      {p.value.toFixed(1)}
                    </text>
                    <text
                      class="axis-label x-label"
                      x={p.x}
                      y={chartH - padB + 22}
                      transform={`rotate(-45 ${fmt(p.x)} ${chartH - padB + 22})`}
                    >
                      {p.year}
                    </text>
                  </g>
                );
              })}

              <text class="axis-title" x={padL - 48} y={padT + plotH / 2} transform={`rotate(-90 ${padL - 48} ${padT + plotH / 2})`}>
                Million metric tons
              </text>
              <text class="axis-title" x={padL + plotW / 2} y={chartH - 6}>Year</text>
            </svg>
            <figcaption>
              <span>Global copper production</span>
              <cite>U.S. Geological Survey, Mineral Commodity Summaries, 1850–2025</cite>
            </figcaption>
          </figure>

          <blockquote class="pull-quote thesis-quote" data-reveal style="--i:2">
            <p>In order to maintain our global economic growth at 3%, we have to mine as much copper in the next 18 years as we have mined in the past 10,000 years.</p>
            <cite>Robert Friedland, <span>Mining Legend</span></cite>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <section class="section soft" id="policy">
    <div class="wrap">
      <div class="section-spread section-spread--reverse">
        <header class="section-intro" data-reveal>
          <h2 class="section-title">Argentina is Back in Mining</h2>
          <p class="section-lead">For decades, political mismanagement and overregulation kept miners out of Argentina, creating a profound valuation gap compared to its neighbors. President Milei's pro-business reforms are re-rating Argentina's mining and exploration assets.</p>
          <div class="policy-card">
            <h3>The Milei Effect</h3>
            <p class="policy-card-sub">Re-rating a century of missed opportunity.</p>
            <ul>
              {mileiItems.map(([title, desc]) => (
                <li>
                  <span class="mi" aria-hidden="true">check_circle</span>
                  <div>
                    <strong>{title}</strong>
                    {desc}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </header>

        <div class="section-evidence section-evidence--policy" data-reveal style="--i:1">
          <div class="split-visual split-visual--medium">
            <div class="split-image">
              <img data-parallax src={asset("images/general/mining-haul-trucks-pit.webp")} alt="Haul trucks descending an open-pit copper mine, illustrating the scale of modern copper production" loading="lazy" width="1600" height="2133" />
            </div>
            <div class="split-badge">
              <strong>Top 5</strong>
              <span>Argentina's Potential as a Global Copper Producer</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section soft" id="geology">
    <div class="wrap">
      <div class="section-spread">
        <header class="section-intro" data-reveal>
          <h2 class="section-title">Geology Doesn't Stop at the Border</h2>
          <p class="section-lead">Chile and Argentina share the same geology: the Andean Copper Belt, one of the most prolific copper regions in the world. Chile has mined its side for a century. Argentina's is virtually untouched.</p>
          <div class="gap-card">
            <header class="gap-card-head">
              <h3>Closing the Copper Gap</h3>
              <p>Two countries. One geology. The data tells the story.</p>
            </header>
            <div class="dtw gap-table-wrap" tabindex="0" role="region" aria-label="Copper production comparison: Chile vs Argentina">
              <table class="dt gap-table" aria-describedby="gap-table-source">
                <thead>
                  <tr>
                    <th scope="col">Metric</th>
                    <th scope="col" class="num">Chile</th>
                    <th scope="col" class="num">Argentina</th>
                  </tr>
                </thead>
                <tbody>
                  <tr data-reveal data-reveal-effect="fade" style="--i:0">
                    <th scope="row">Top 20 global copper mines</th>
                    <td class="num">7</td>
                    <td class="num">0</td>
                  </tr>
                  <tr data-reveal data-reveal-effect="fade" style="--i:1">
                    <th scope="row">Share of world copper production</th>
                    <td class="num">23%</td>
                    <td class="num">0%</td>
                  </tr>
                  <tr data-reveal data-reveal-effect="fade" style="--i:2">
                    <th scope="row">Annual production, current</th>
                    <td class="num">5.3 Mt</td>
                    <td class="num">0.0 Mt</td>
                  </tr>
                  <tr data-reveal data-reveal-effect="fade" class="row-emphasis" style="--i:3">
                    <th scope="row">Annual production, potential</th>
                    <td class="num">6.0 Mt</td>
                    <td class="num hi">2.0+ Mt</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p class="source-note" id="gap-table-source">COCHILCO 2024, Cámara Argentina de Empresarios Mineros; potential figures based on independent geological-belt analysis. As of Q1 2026.</p>
          </div>
        </header>

        <div class="section-evidence" data-reveal style="--i:1">
          <div class="rocks-map">
            <AndesHero
              client:visible
              fallbackSrc={asset("images/projects/map_fallback_vertical.webp")}
              fallbackAlt="Southern Andes copper belt across the Chile–Argentina border with Argentina Metals' Las Estrellas flagship"
            />
          </div>
          <MapLegend />
        </div>

        <script>
          const warm = () => import("maplibre-gl").catch(() => {});
          if ("requestIdleCallback" in window) {
            (window as Window & { requestIdleCallback: (cb: () => void, opts?: { timeout: number }) => void }).requestIdleCallback(warm, { timeout: 2500 });
          } else {
            setTimeout(warm, 800);
          }
        </script>
      </div>
    </div>
  </section>

  <section class="section" id="land">
    <div class="wrap">
      <div class="section-spread section-spread--reverse">
        <header class="section-intro" data-reveal>
          <h2 class="section-title">District Scale Exploration</h2>
          <p class="section-lead">Our land position across Argentina's Malargüe District lets us focus capital on the most promising structures across an entire belt, rather than chasing isolated targets in a single licence.</p>
          <div class="hectares-banner hectares-banner--column">
            <div class="hectares-banner-figure">
              <strong>
                <span aria-label="146,728">146,728</span>
              </strong>
              <span class="hectares-banner-unit">hectares</span>
            </div>
            <div class="hectares-banner-body">
              <p class="hectares-banner-lead">Land position in Mendoza Province.</p>
              <p class="hectares-banner-context">For context: the Escondida mine concession in Chile, the world's largest copper operation, covers approximately 14,500 ha.</p>
            </div>
          </div>
          <div class="district-status">
            <span class="district-status-dot" aria-hidden="true"></span>
            <div>
              <strong>More licences under negotiation</strong>
              <span>Strategic acquisitions actively expanding the package.</span>
            </div>
          </div>
        </header>

        <div class="section-evidence" data-reveal style="--i:1">
          <figure class="district-map">
            <div class="district-map-frame">
              <img
                src={asset("images/projects/malargue-claims-map.webp")}
                alt="Claims map of the Malargüe District in Mendoza, Argentina, showing Argentina Metals tenures in green alongside neighbouring Kobrea Exploration tenures in blue, across 26 named licenses straddling the Chile–Argentina border."
                loading="lazy"
                width="889"
                height="1287"
              />
            </div>
            <figcaption>Claims map, Malargüe District, Mendoza Province</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <section class="section soft" id="technology">
    <div class="wrap">
      <div class="section-spread">
        <header class="section-intro" data-reveal>
          <h2 class="section-title">Newest Technologies</h2>
          <p class="section-lead">Never before in history have so much data about the surface been available. We combine sophisticated satellite imagery, invaluable for early-stage exploration, with specialized software to compile and compare the data.</p>
          <ul class="tech-stats">
            <li data-reveal data-reveal-effect="quiet" style="--i:0">
              <span class="mi" aria-hidden="true">satellite_alt</span>
              <strong>Multispectral &amp; hyperspectral imagery</strong>
              <span>Stacked satellite passes across the licence area for alteration mapping.</span>
            </li>
            <li data-reveal data-reveal-effect="quiet" style="--i:1">
              <span class="mi" aria-hidden="true">flight</span>
              <strong>Drone magnetic &amp; photogrammetric surveys</strong>
              <span>High-resolution coverage of priority targets, without chartering a helicopter.</span>
            </li>
            <li data-reveal data-reveal-effect="quiet" style="--i:2">
              <span class="mi" aria-hidden="true">insights</span>
              <strong>Machine-learning target generation</strong>
              <span>Geophysics + remote sensing fused to rank targets before boots-on-the-ground.</span>
            </li>
          </ul>
        </header>

        <div class="section-evidence" data-reveal style="--i:1">
          <figure class="tech-image">
            <div class="split-image">
              <img data-parallax src={asset("images/projects/Spectral-evaluation.webp")} alt="Multispectral satellite evaluation of alteration zones across Argentina Metals' Mendoza licences" loading="lazy" width="731" height="512" />
            </div>
            <figcaption>Spectral based target evaluation</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <section class="section compact-top" id="team">
    <div class="wrap">
      <div class="section-spread section-spread--stack">
        <header class="section-intro" data-reveal>
          <h2 class="section-title">Extraordinary Team</h2>
          <p class="section-lead">A team of senior and junior geologists drawn from Europe, North and South America. Different and complementary skill sets, organised around one task: to find world-class copper deposits in Argentina.</p>
        </header>

        <div class="section-evidence">
          <div class="team-strip" aria-label="Board of Directors">
            <ul class="team-strip-faces" role="list">
              <li data-reveal data-reveal-effect="quiet" style="--i:0">
                <a href="/team#raymond-d-harari" aria-label="Raymond D. Harari, CEO">
                  <img src={asset("images/people/Raymond D. Harari.webp")} alt="Portrait of Raymond D. Harari" loading="lazy" width="96" height="96" />
                  <span class="team-strip-name">Raymond D. Harari</span>
                </a>
              </li>
              <li data-reveal data-reveal-effect="quiet" style="--i:1">
                <a href="/team#titus-gebel" aria-label="Titus Gebel, Chairman">
                  <img src={asset("images/people/Titus Gebel.webp")} alt="Portrait of Titus Gebel" loading="lazy" width="96" height="96" />
                  <span class="team-strip-name">Titus Gebel</span>
                </a>
              </li>
              <li data-reveal data-reveal-effect="quiet" style="--i:2">
                <a href="/team#julio-pulisich" aria-label="Julio Pulisich, Director">
                  <img src={asset("images/people/Julio Pulisich.webp")} alt="Portrait of Julio Pulisich" loading="lazy" width="96" height="96" />
                  <span class="team-strip-name">Julio Pulisich</span>
                </a>
              </li>
              <li data-reveal data-reveal-effect="quiet" style="--i:3">
                <a href="/team#tim-heenan" aria-label="Tim Heenan, Director">
                  <img src={asset("images/people/Timothy Heenan.webp")} alt="Portrait of Tim Heenan" loading="lazy" width="96" height="96" />
                  <span class="team-strip-name">Tim Heenan</span>
                </a>
              </li>
              <li data-reveal data-reveal-effect="quiet" style="--i:4">
                <a href="/team#martin-hoff" aria-label="Martin Hoff, Director">
                  <img src={asset("images/people/Martin Hoff.webp")} alt="Portrait of Martin Hoff" loading="lazy" width="96" height="96" />
                  <span class="team-strip-name">Martin Hoff</span>
                </a>
              </li>
            </ul>
            <a class="team-strip-link" href="/team" data-reveal data-reveal-effect="quiet" style="--i:5">Meet the full team <span class="mi" aria-hidden="true">arrow_forward</span></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="closing-cta" id="invest" aria-label="Next steps for investors">
    <div class="wrap">
      <div class="closing-cta-inner">
        <div class="closing-cta-copy" data-reveal style="--i:0">
          <h2>Build conviction at your own pace.</h2>
          <p>Read the corporate presentation or subscribe to drilling and news alerts.</p>
        </div>
        <div class="closing-cta-actions" data-reveal style="--i:1">
          <a class="button copper" href="/investor#docs">Corporate Presentation</a>
          <a class="button secondary on-dark" href="/subscribe">Subscribe to Alerts</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
