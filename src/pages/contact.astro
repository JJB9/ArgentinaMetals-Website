---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/PageHeader.astro";
---

<BaseLayout
  title="Contact - Argentina Metals"
  description="Get in touch with Argentina Metals Corp. for investor relations, partnerships, media or technical enquiries about our Mendoza copper projects."
>
  <PageHeader
    title="Contact"
  />
  <section class="content-band">
    <div class="wrap contact-layout">
      <aside class="contact-imagecard" aria-hidden="true">
        <img
          src="/images/projects/LasEstrellas/lasestrellas1.webp"
          alt=""
          width="1406"
          height="2500"
          loading="lazy"
          decoding="async"
          fetchpriority="low"
        />
      </aside>

      <form class="contact-form" name="contact" method="post" data-netlify="true" data-netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contact" />
        <p hidden aria-hidden="true" style="display:none">
          <label>Don't fill this out if you're human: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
        </p>
        <div class="form-grid">
          <label>First Name<input class="form-input" type="text" name="first-name" placeholder="John" /></label>
          <label>Last Name<input class="form-input" type="text" name="last-name" placeholder="Smith" /></label>
          <label>Email<input class="form-input" type="email" name="email" placeholder="john@example.com" required /></label>
          <label>Topic<select class="form-input" name="topic">
            <option value="">Select a topic</option>
            <option value="general">General Inquiry</option>
            <option value="investment">Investment &amp; IR</option>
            <option value="partnership">Partnership Opportunity</option>
            <option value="media">Media &amp; Press</option>
            <option value="technical">Technical / Projects</option>
            <option value="other">Other</option>
          </select></label>
          <label class="full">Message<textarea class="form-input" name="message" placeholder="How can we help?" required></textarea></label>
        </div>
        <button class="button primary" type="submit">Send Message <span class="mi" aria-hidden="true">arrow_forward</span></button>
      </form>
    </div>
  </section>
</BaseLayout>
