---
import BaseLayout from "@layouts/BaseLayout.astro";
import KeyFactsBox, { type KeyFact } from "@components/KeyFactsBox.astro";

const base = import.meta.env.BASE_URL;
const img = (path: string) => `${base}assets/images/projects/${path}`;

const keyFacts: KeyFact[] = [
  { icon: "location_on", label: "Location", value: "Mendoza Province, Argentina" },
  { icon: "science", label: "Commodities", value: "Copper (primary), gold, silver" },
  { icon: "schedule", label: "Current Phase", value: "Phase 2 — Target Definition" },
  { icon: "landscape", label: "District Land Package", value: "146,728 ha consolidated" }
];

const rockChips = [
  { label: "Samples > 50 ppm Cu", value: "17", hi: false },
  { label: "Samples > 100 ppm Cu", value: "5", hi: false },
  { label: "Peak — G2R-287", value: "6,673 ppm Cu", hi: true },
  { label: "Peak — G2R-271", value: "9,978 ppm Cu", hi: true }
];

const geophysHighlights = [
  {
    icon: "north",
    title: "Depth — 50–150 m",
    text: "Main magnetic sources at 50–60 m and 120–150 m — shallow and drill-accessible."
  },
  {
    icon: "polyline",
    title: "Structural alignment",
    text: "Strong correlation with NW–SE and N–S lineaments that control hydrothermal fluid pathways."
  },
  {
    icon: "sensors",
    title: "IOCG / porphyry signature",
    text: "Pattern consistent with IOCG-style mineralisation and/or partially buried porphyry systems."
  },
  {
    icon: "center_focus_strong",
    title: "Geochem–geophys overlap",
    text: "Magnetic highs coincide with rock chip peaks in the north-central and eastern sectors."
  }
];

const roadmap = [
  {
    phase: "Phase 01",
    status: "Completed",
    title: "Surface & Geophysics",
    text: "Initial mapping, geochemistry, property-scale magnetometric survey. 144 rock chips plus 14 stream-sediment samples defined the primary targeting zone."
  },
  {
    phase: "Phase 02",
    status: "Current",
    title: "Target Definition",
    text: "IP surveys, target refinement, and pre-drill work across the north-central and eastern anomalies. Additional license acquisition in the satellite corridor."
  },
  {
    phase: "Phase 03",
    status: "Next",
    title: "Maiden Drill Program",
    text: "Drill-testing of highest-priority targets confirmed through Phase 2 — with access and logistics staged from Malargüe town."
  }
];
---

<BaseLayout
  title="Las Estrellas — Flagship Cu-Au Project | Argentina Metals Corp."
  description="Las Estrellas is Argentina Metals' flagship copper-gold project in the Western Malargüe Mining District, Mendoza. Two mineralisation models confirmed by surface geochemistry and magnetometric surveys, with drill-ready targets at 50–150 m."
>
  <section class="page-hero page-hero--split page-hero--project">
    <div class="wrap">
      <div class="page-hero-text">
        <a class="page-hero-back" href="/projects" data-reveal style="--i:0">
          <span class="mi" aria-hidden="true">arrow_back</span>
          All Projects
        </a>
        <h1 data-reveal style="--i:1">Las Estrellas</h1>
        <p data-reveal style="--i:2">The flagship of Argentina Metals' 146,728-hectare Western Malargüe land position — a copper-gold project where two distinct mineralising systems have been confirmed by surface geochemistry and property-scale geophysics.</p>
      </div>
      <aside class="page-hero-aside" data-reveal style="--i:2">
        <KeyFactsBox
          title="Project Snapshot"
          facts={keyFacts}
          columns={2}
        />
      </aside>
    </div>
  </section>

  <section class="section compact-top">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">A corridor that hosts world-class copper</h2>
          <p class="section-desc">Las Estrellas sits inside the same Andean copper belt that hosts Chile's producing super-giants — yet the Argentine side of the divide has remained largely untested. The project is 1.5 km from an actively drilled porphyry target operated by a neighbour.</p>
        </div>
      </div>

      <div class="lede-grid" data-reveal>
        <div class="lede-grid-text">
          <p>Acquired in <strong>November 2025</strong> as one of Argentina Metals' four founding properties, Las Estrellas quickly emerged as the flagship on the strength of its early field results. Two distinct copper mineralising systems have been recognised on the property — each expanding the discovery envelope on its own terms.</p>
          <p>Having two independent models inside a single land position is uncommon. It meaningfully broadens the opportunity and means the project can deliver value under more than one geological outcome.</p>
        </div>
        <figure class="lede-grid-img">
          <img src={img("andes-argentina-clouds.jpg")} alt="Moody clouds over the Argentine Andes, characteristic of the Western Malargüe setting" loading="lazy" />
        </figure>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Two mineralising systems, one property</h2>
          <p class="section-desc">The discovery case rests on two independent copper styles — both present at surface, both drill-targetable, and each capable of carrying the project on its own.</p>
        </div>
      </div>

      <div class="model-grid">
        <article class="model-card" data-reveal style="--i:0">
          <div class="model-card-img">
            <img src={img("distant-mountain-arid-rocky.jpg")} alt="Rocky desert and distant arid mountains — the kind of setting hosting manto-type copper in the Río Damas Formation" loading="lazy" />
            <span class="model-card-tag">Model 01</span>
          </div>
          <div class="model-card-body">
            <span class="mi model-card-icon" aria-hidden="true">layers</span>
            <h3>Manto-type Copper</h3>
            <p class="model-card-lead">Copper oxides linked to andesitic flows intruding Jurassic red sandstones of the <strong>Río Damas Formation</strong>, with possible skarn-style mineralisation at depth.</p>
            <ul class="model-card-bullets">
              <li><span class="mi" aria-hidden="true">check_circle</span> Stratabound, accessible at surface</li>
              <li><span class="mi" aria-hidden="true">check_circle</span> Historic small-scale Cu workings in the district</li>
              <li><span class="mi" aria-hidden="true">check_circle</span> Skarn potential at depth adds upside</li>
            </ul>
          </div>
        </article>

        <article class="model-card" data-reveal style="--i:1">
          <div class="model-card-img">
            <img src={img("stunning-arid-mountain-daylight.jpg")} alt="Arid mountain terrain in daylight — terrain style typical of Neogene porphyry settings" loading="lazy" />
            <span class="model-card-tag">Model 02</span>
          </div>
          <div class="model-card-body">
            <span class="mi model-card-icon" aria-hidden="true">volcano</span>
            <h3>Porphyry Copper-Gold</h3>
            <p class="model-card-lead">Andesitic outcrops and dacitic bodies of the <strong>Huincán Formation</strong> with geological similarities to nearby Neogene porphyry systems — including the El Perdido prospect being drilled 1.5 km west.</p>
            <ul class="model-card-bullets">
              <li><span class="mi" aria-hidden="true">check_circle</span> Analogous to Chilean-side producing belts</li>
              <li><span class="mi" aria-hidden="true">check_circle</span> Neighbouring drill activity validates thesis</li>
              <li><span class="mi" aria-hidden="true">check_circle</span> Scale potential for a Tier-1 discovery</li>
            </ul>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Rock chip highlights</h2>
          <p class="section-desc">The December 2025 field program collected 144 surface rock chip and talus samples plus 14 stream-sediment samples across the property — and the four highest-copper samples cluster in a single target zone in the <strong>northern sector</strong>.</p>
        </div>
      </div>

      <div class="geo-layout">
        <div class="dtw" data-reveal>
          <table class="dt">
            <thead>
              <tr>
                <th scope="col">Threshold</th>
                <th scope="col" class="num">Value</th>
              </tr>
            </thead>
            <tbody>
              {rockChips.map((row) => (
                <tr>
                  <th scope="row" class:list={{ hi: row.hi }}>{row.label}</th>
                  <td class:list={["num", { hi: row.hi }]}>{row.value}</td>
                </tr>
              ))}
              <tr>
                <th scope="row">Total samples collected</th>
                <td class="num">144 rock / 14 stream</td>
              </tr>
            </tbody>
          </table>
        </div>
        <figure class="geo-img" data-reveal>
          <img src={img("copper-mineral-close-up.jpg")} alt="Close-up of copper mineralisation in rock — representative of the oxide copper encountered at Las Estrellas" loading="lazy" />
          <figcaption>
            <strong>Peak 9,978 ppm Cu</strong>
            <span>Sample G2R-271 — northern target zone</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Magnetometric signature</h2>
          <p class="section-desc">The January 2026 property-scale AMT magnetometric survey (RTP, Analytical Signal, TDR, SPI, Euler, spectral) returned amplitudes from approximately −1,050 to +800 nT — consistent with ferromagnetic minerals linked to mafic-to-intermediate intrusive bodies.</p>
        </div>
      </div>

      <div class="geophys-grid">
        {geophysHighlights.map((item, i) => (
          <article class="geophys-card" data-reveal style={`--i:${i}`}>
            <span class="geophys-icon" aria-hidden="true">
              <span class="mi">{item.icon}</span>
            </span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>

      <p class="geophys-note" data-reveal>Surface geochemistry and geophysics are aligned — both point to the same zones for follow-up.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-header" data-reveal>
        <div>
          <h2 class="section-title">Exploration roadmap</h2>
          <p class="section-desc">Three phases from consolidation through discovery. Phase 2 is underway, with drill targets refined through IP and continued geochemical work.</p>
        </div>
      </div>

      <div class="timeline-grid">
        {roadmap.map((item, i) => (
          <article class="timeline-card" data-reveal style={`--i:${i}`}>
            <div class="timeline-top">
              <span>{item.phase}</span>
              <strong>{item.status}</strong>
            </div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="callout" data-reveal>
        <div>
          <span>District context</span>
          <h2>Las Estrellas anchors a 146,728-hectare consolidated land position.</h2>
          <p>Assembled from 24 fragmented private holdings plus 2 newly staked properties, with 100+ GIS-identified targets across the wider Western Malargüe Mining District. Drill success by neighbours validates the geological thesis for the entire corridor.</p>
        </div>
        <a class="button primary" href="/projects">See the portfolio <span class="mi" aria-hidden="true">arrow_forward</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
