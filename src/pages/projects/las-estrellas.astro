---
import BaseLayout from "@layouts/BaseLayout.astro";
import KeyFactsBox, { type KeyFact } from "@components/KeyFactsBox.astro";
import lasEstrellasData from "../../data/projects/las-estrellas.json";

const base = import.meta.env.BASE_URL;
const leImg = (path: string) => `${base}images/projects/LasEstrellas/${path}`;

const keyFacts: KeyFact[] = [
  { icon: "location_on", label: "Location", value: "Mendoza Province, Argentina" },
  { icon: "science", label: "Commodities", value: "Copper (primary), gold, silver" },
  { icon: "schedule", label: "Current Phase", value: "Phase 2: Target Definition" },
  { icon: "landscape", label: "District Land Package", value: "146,728 ha consolidated" }
];

const rockChips = [
  { label: "Samples > 50 ppm Cu", value: "17", hi: false },
  { label: "Samples > 100 ppm Cu", value: "5", hi: false },
  { label: "Peak (G2R-287)", value: "6,673 ppm Cu", hi: true },
  { label: "Peak (G2R-271)", value: "9,978 ppm Cu", hi: true }
];

const anomalyMaps = [
  {
    src: "LE-copper.webp",
    alt: "Property-scale copper anomaly map from the December 2025 rock chip program at Las Estrellas",
    caption: "Copper anomalies",
    sub: "Rock chip / talus sample values across the property"
  },
  {
    src: "LE-geophysics.webp",
    alt: "Property-scale ground magnetometric signature map at Las Estrellas, January 2026 AMT survey",
    caption: "Magnetometric signature",
    sub: "Reduced-to-pole intensity from the January 2026 AMT survey"
  },
  {
    src: "LE-silver.webp",
    alt: "Property-scale silver anomaly map from the December 2025 rock chip program at Las Estrellas",
    caption: "Silver anomalies",
    sub: "Rock chip / talus sample values across the property"
  }
];

const samples = [
  {
    src: "argentina-metals-las-estrellas-copper-sample.webp",
    alt: "Sample G2R-271 in gloved hands, peak 9,978 ppm Cu from the northern target zone at Las Estrellas",
    id: "G2R-271",
    grade: "9,978 ppm Cu",
    note: "Northern target zone"
  },
  {
    src: "argentina-metals-las-estrellas-copper-sample-332.webp",
    alt: "Sample G2R-332 held up against the property sky, 326 ppm Cu",
    id: "G2R-332",
    grade: "326 ppm Cu",
    note: "Anomalous halo"
  },
  {
    src: "argentina-metals-las-estrellas-copper-sample-size.webp",
    alt: "Large oxidised copper-bearing sample with orange pen for scale, collected at Las Estrellas",
    id: "Bulk sample",
    grade: "Oxidised Cu",
    note: "Pen for scale"
  }
];

const technicalReport = lasEstrellasData.technicalReport;
---

<BaseLayout title="Las Estrellas · Cu-Au Project | Argentina Metals">
  <div class="page-progress" aria-hidden="true"><span></span></div>

  <section class="page-hero page-hero--split page-hero--project">
    <div class="wrap">
      <div class="page-hero-text">
        <a class="page-hero-back" href="/projects" data-reveal style="--i:0">
          <span class="mi" aria-hidden="true">arrow_back</span>
          All Projects
        </a>
        <h1 data-reveal style="--i:1">Las Estrellas</h1>
        <p data-reveal style="--i:2">Argentina Metals' lead copper-gold project on the 146,728-hectare Western Malargüe land position. Surface geochemistry and a property-scale magnetometric survey have defined targets in two distinct zones.</p>
      </div>
      <div class="page-hero-aside" data-reveal style="--i:2">
        <KeyFactsBox
          title="Project Snapshot"
          facts={keyFacts}
          columns={2}
        />
        {technicalReport && (
          <a class="report-box" href={technicalReport} download>
            <span class="report-box-icon" aria-hidden="true">
              <span class="mi">picture_as_pdf</span>
            </span>
            <span class="report-box-text">
              <strong>Technical report</strong>
              <span>Full geological summary, geochemistry tables and figures.</span>
            </span>
            <span class="report-box-action">
              <span>Download PDF</span>
              <span class="mi" aria-hidden="true">arrow_forward</span>
            </span>
          </a>
        )}
      </div>
    </div>
  </section>

  <section class="section section--sand" id="exploration">
    <div class="wrap">
      <div class="spread-4-4-4" data-reveal>
        <header class="spread-4-4-4-title">
          <h2 class="section-title">Exploration</h2>
          <p class="spread-4-4-4-tag">December 2025 field program</p>
        </header>
        <div class="spread-4-4-4-narrative">
          <p>The initial exploration work carried out in Las Estrellas in December 2025 identified a large area occupied by volcanic rocks of andesitic-basaltic composition. Geological mapping, ground-based magnetometry and sampling were carried out throughout the property area.</p>
          <p>The four highest-copper samples cluster in a single target zone in the <span class="text-accent">northern sector</span> of the property.</p>
        </div>
        <div class="spread-4-4-4-table dtw" tabindex="0" role="region" aria-label="Highest copper sample results from December 2025 field program">
          <table class="dt">
            <thead>
              <tr>
                <th scope="col">Threshold</th>
                <th scope="col" class="num">Value</th>
              </tr>
            </thead>
            <tbody>
              {rockChips.map((row) => (
                <tr>
                  <th scope="row" class:list={{ hi: row.hi }}>{row.label}</th>
                  <td class:list={["num", { hi: row.hi }]}>{row.value}</td>
                </tr>
              ))}
              <tr>
                <th scope="row">Total samples collected</th>
                <td class="num">144 rock / 14 stream</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="sample-strip">
        {samples.map((s, i) => {
          const dims = s.src === "argentina-metals-las-estrellas-copper-sample.webp"
            ? { width: 733, height: 1300 }
            : { width: 1000, height: 562 };
          return (
          <figure class="sample-strip-item" data-reveal style={`--i:${i}`}>
            <div class="sample-strip-frame">
              <img src={leImg(s.src)} alt={s.alt} loading="lazy" decoding="async" width={dims.width} height={dims.height} />
            </div>
            <figcaption>
              <span class="code-pill">{s.id}</span>
              <strong>{s.grade}</strong>
              <span class="sample-strip-note">{s.note}</span>
            </figcaption>
          </figure>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section" id="anomaly-maps">
    <div class="wrap">
      <div class="maps-sticky">
        <header class="maps-sticky-header" data-reveal>
          <h2 class="section-title">Project maps</h2>
          <p class="section-desc">Surface geochemistry and ground magnetometry produced three property-scale plates that together frame the discovery case: copper and silver from rock chip sampling, alongside the magnetic signature of the underlying intrusive bodies.</p>
          <p class="maps-sticky-meta">Plates · January 2026</p>
        </header>
        <div class="maps-sticky-body">
          <div class="maps-grid">
            {anomalyMaps.map((m, i) => (
              <figure
                class="maps-grid-item"
                data-reveal
                style={`--i:${i}`}
                tabindex="0"
                role="button"
                aria-label={`Open ${m.caption} map at full size`}
                data-map-src={leImg(m.src)}
                data-map-alt={m.alt}
                data-map-caption={m.caption}
                data-map-sub={m.sub}
              >
                <div class="maps-grid-frame">
                  <span class="maps-grid-corner maps-grid-corner--n" aria-hidden="true">N ↑</span>
                  <img src={leImg(m.src)} alt={m.alt} loading="lazy" decoding="async" width="1061" height="1500" />
                </div>
                <figcaption>
                  <strong>{m.caption}</strong>
                  <span>{m.sub}</span>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </div>
    </div>

    <dialog class="maps-lightbox" id="maps-lightbox" aria-labelledby="maps-lightbox-caption">
      <button class="maps-lightbox-close" type="button" aria-label="Close map preview">
        <span class="mi" aria-hidden="true">close</span>
      </button>
      <figure class="maps-lightbox-figure">
        <img src="" alt="" />
        <figcaption id="maps-lightbox-caption">
          <strong></strong>
          <span></span>
        </figcaption>
      </figure>
    </dialog>

    <script is:inline>
      (() => {
        const dialog = document.getElementById("maps-lightbox");
        if (!dialog || typeof dialog.showModal !== "function") return;
        const img = dialog.querySelector("img");
        const captionStrong = dialog.querySelector("figcaption strong");
        const captionSpan = dialog.querySelector("figcaption span");
        const closeBtn = dialog.querySelector(".maps-lightbox-close");

        const open = (el) => {
          img.src = el.dataset.mapSrc;
          img.alt = el.dataset.mapAlt;
          captionStrong.textContent = el.dataset.mapCaption;
          captionSpan.textContent = el.dataset.mapSub;
          dialog.showModal();
        };

        document.querySelectorAll(".maps-grid-item").forEach((el) => {
          el.addEventListener("click", () => open(el));
          el.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              open(el);
            }
          });
        });

        closeBtn.addEventListener("click", () => dialog.close());
        dialog.addEventListener("click", (e) => {
          if (e.target === dialog) dialog.close();
        });
      })();
    </script>
  </section>

  <section class="section section--sand" id="conclusion">
    <div class="wrap">
      <div class="section-header section-header--single" data-reveal>
        <div>
          <h2 class="section-title">Conclusion</h2>
          <p class="section-desc">Two distinct interpretations emerge along the property: a mineralised target in the north, and the periphery of a porphyry system in the south.</p>
        </div>
      </div>

      <div class="conclusion-pair">
        <article class="conclusion-card conclusion-card--north" data-reveal style="--i:0">
          <div class="conclusion-card-photo">
            <img src={leImg("argentina-metals-las-estrellas.webp")} alt="Copper-mineralised rock outcrop with rock hammer for scale, Las Estrellas northern zone" loading="lazy" decoding="async" width="1000" height="562" />
          </div>
          <div class="conclusion-card-body">
            <span class="conclusion-tag">Northern zone</span>
            <h3>El Burrero-style copper-silver mantle</h3>
            <p>In the northern part, there is a potential mineralized zone that would correspond to the <span class="text-accent">El Burrero</span> mine model: a volcanic mantle-type deposit of copper and silver, with some indications of a possible skarn or IOCG as well.</p>
          </div>
        </article>
        <article class="conclusion-card conclusion-card--south" data-reveal style="--i:1">
          <div class="conclusion-card-photo">
            <img src={leImg("argentina-metals-copper-opportunity.webp")} alt="Altered yellow-orange slope at Las Estrellas, characteristic of the porphyry-margin alteration in the southern zone" loading="lazy" decoding="async" width="731" height="1300" />
          </div>
          <div class="conclusion-card-body">
            <span class="conclusion-tag">Southern zone</span>
            <h3>Porphyry copper system periphery</h3>
            <p>In the southern part, geochemistry indicates a peripheral zone of a porphyry copper system: relatively high values of arsenic and lead, and low values of copper and molybdenum.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

</BaseLayout>
