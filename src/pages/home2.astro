---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path}`;
const news = (await getCollection("news"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) => date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});

const heroStats = [
  ["146k+", "Hectares Controlled"],
  ["26", "Project Areas", "copper"],
  ["#7", "Global Copper Rank"],
  ["~60%", "Insider Ownership", "copper"]
];

const tickerItems = [
  ["Copper Price", "$4.85/lb"],
  ["146,000+ Hectares", ""],
  ["26 Project Areas", ""],
  ["San Juan & Catamarca Provinces", ""],
  ["Andean Copper Belt", ""],
  ["NI 43-101 Technical Report Filed", ""],
  ["Up to", "9,978 ppm Cu at Las Estrellas"]
];

const thesisCards = [
  {
    icon: "landscape",
    title: "Same Geology",
    text: "Argentina shares the high-grade Andean belt with Chile — the world's #1 producer — yet remains chronically underexplored with a fraction of the capital invested."
  },
  {
    icon: "trending_up",
    title: "Mining Reset",
    text: "President Milei's pro-business reforms are sparking a structural re-rating of Argentine mining assets across every stage of development.",
    variant: "dark"
  },
  {
    icon: "zoom_out_map",
    title: "District Scale",
    text: "Amassing 146,000+ hectares across prime districts before the surge in major M&A activity reshapes the region.",
    variant: "copper"
  }
];

const mileiSteps = [
  {
    year: "Capital Controls Lifted",
    title: "Free Flow of Investment",
    desc: "Elimination of capital controls incentivizes major foreign direct investment into Argentine mining for the first time in a generation."
  },
  {
    year: "RIGI Implementation",
    title: "30-Year Tax Stability",
    desc: "The Large Investment Incentive Regime (RIGI) guarantees fiscal predictability — a transformational shift for long-cycle mining projects."
  },
  {
    year: "Provincial Alignment",
    title: "Pro-Mining Governance",
    desc: "Key provinces like San Juan and Catamarca are actively courting developers with streamlined permitting and infrastructure support."
  }
];
---

<BaseLayout
  title="Argentina Metals Corp. - A Pure-Play on Argentina's Copper Boom"
  description="Argentina Metals Corp. is acquiring district-scale copper exploration assets across Argentina's underexplored Andean copper belts."
>
  <section class="hero">
    <div class="wrap">
      <span class="hero-tag">TSX-V: VLLC</span>
      <h1>A Pure-Play on Argentina's <em>Copper Boom</em></h1>
      <p>Acquiring premium assets in the world's #7 copper region while the market re-prices the Milei Effect.</p>
      <div class="hero-actions">
        <a class="button primary" href="#thesis">Explore the Opportunity <span class="mi" aria-hidden="true">arrow_forward</span></a>
        <a class="button secondary" href="/investor">View Investor Deck</a>
      </div>
    </div>
  </section>

  <div class="hero-media">
    <div class="hero-media-frame">
      <video autoplay muted loop playsinline src={asset("assets/images/case-video.mp4")}></video>
    </div>
  </div>

  <div class="wrap hero-stats-wrap">
    <div class="hero-stats">
      {heroStats.map(([val, lbl, variant]) => (
        <div>
          <span class:list={["hero-stat-val", variant]}>{val}</span>
          <span class="hero-stat-lbl">{lbl}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {[...tickerItems, ...tickerItems].map(([a, b]) => (
        <span class="ticker-item">
          <span class="ticker-dot" aria-hidden="true"></span>
          {a}{b && <> <strong>{b}</strong></>}
        </span>
      ))}
    </div>
  </div>

  <section class="section" id="thesis">
    <div class="wrap">
      <div class="section-header">
        <span class="section-num">01</span>
        <div>
          <h2 class="section-title">Three pillars define our approach to the Argentine copper boom.</h2>
          <p class="section-desc">A strategy built on geology, policy, and scale — before the rush begins.</p>
        </div>
      </div>

      <div class="bento">
        {thesisCards.map((card) => (
          <article class:list={["bento-card", card.variant]}>
            <span class="mi bento-ic" aria-hidden="true">{card.icon}</span>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
        <article class="bento-card span2">
          <div class="bento-split">
            <div>
              <span class="bento-val copper">$30B+</span>
              <p>Regional investment pipeline announced by majors for Argentine copper-gold projects over the coming decade.</p>
            </div>
            <div>
              <span class="bento-val">#7</span>
              <p>Argentina's global ranking for copper reserve potential — virtually untouched compared to #1 neighbor Chile.</p>
            </div>
          </div>
        </article>
        <article class="bento-card">
          <span class="mi bento-ic" aria-hidden="true">verified</span>
          <h3>NI 43-101 Filed</h3>
          <p>Independent technical report completed covering the full 146,728-hectare land package across 26 project areas.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="wrap">
      <div class="milei-header">
        <div class="section-header">
          <span class="section-num">02</span>
          <div>
            <h2 class="section-title">From overlooked to essential.</h2>
            <p class="section-desc">Decades of political instability kept capital out of Argentina, creating a profound valuation gap. That gap is closing fast — and early movers capture the arbitrage.</p>
          </div>
        </div>
        <div class="milei-badge">
          <strong>Top 10</strong>
          <span>Global Copper Reserves</span>
        </div>
      </div>

      <div class="milei-timeline">
        {mileiSteps.map((step) => (
          <article class="tl-item">
            <span class="tl-dot" aria-hidden="true"></span>
            <span class="tl-year">{step.year}</span>
            <h3 class="tl-title">{step.title}</h3>
            <p class="tl-desc">{step.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-header">
        <span class="section-num">03</span>
        <div>
          <h2 class="section-title">The world cannot decarbonize without copper.</h2>
          <p class="section-desc">A structural deficit driven by unprecedented demand and anemic new supply. The squeeze is here.</p>
        </div>
      </div>

      <div class="rings">
        <article class="ring" style="--progress: 80%">
          <div class="ring-value">80</div>
          <h3>New Mines Needed</h3>
          <p>Required by 2030 to meet basic energy-transition demand.</p>
        </article>
        <article class="ring" style="--progress: 90%">
          <div class="ring-value">3-4x</div>
          <h3>Copper per EV</h3>
          <p>Electric vehicles consume multiples of the copper used in ICE vehicles.</p>
        </article>
        <article class="ring" style="--progress: 64%">
          <div class="ring-value">16y</div>
          <h3>Discovery to Production</h3>
          <p>The timeline to bring new supply online is longer than ever.</p>
        </article>
        <article class="ring" style="--progress: 28%">
          <div class="ring-value">-20%</div>
          <h3>Grade Decline</h3>
          <p>Existing majors face sustained drops in ore quality across the board.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="wrap">
      <div class="section-header">
        <span class="section-num">04</span>
        <div>
          <h2 class="section-title">The rocks don't know they crossed a border.</h2>
          <p class="section-desc">Chile has mined their side of the Andes for a century. Argentina's side is virtually untouched — yet shares the same geological belt, the same intrusive history, and the same copper-gold endowment.</p>
        </div>
      </div>

      <div class="split">
        <div class="split-visual">
          <div class="split-image">
            <img src={asset("assets/images/rock-quarry-geology.jpg")} alt="Andean copper belt landscape" loading="lazy" />
          </div>
          <div class="split-badge">
            <strong>146k+</strong>
            <span>Hectares Controlled</span>
          </div>
        </div>
        <div class="split-copy">
          <ul class="checklist">
            <li><span class="mi" aria-hidden="true">check_circle</span>Elite prospects at entry-level pricing</li>
            <li><span class="mi" aria-hidden="true">check_circle</span>One of the largest private land packages in the region</li>
            <li><span class="mi" aria-hidden="true">check_circle</span>Multi-decade exploration runway across prime belts</li>
            <li><span class="mi" aria-hidden="true">check_circle</span>Drill targets confirmed by magnetometric survey</li>
          </ul>
          <a class="button secondary" href="/projects">Explore Our Projects <span class="mi" aria-hidden="true">arrow_forward</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="wrap">
      <div class="section-header">
        <span class="section-num">05</span>
        <div>
          <h2 class="section-title">Recent updates from Argentina Metals.</h2>
          <p class="section-desc">Press releases and corporate developments.</p>
        </div>
      </div>

      <div class="news-grid">
        {news.map((item) => (
          <a class="news-card" href="/news">
            {item.data.image && (
              <div class="news-card-img">
                <img src={item.data.image} alt={item.data.imageAlt ?? item.data.title} loading="lazy" />
              </div>
            )}
            <div class="news-card-body">
              <span class:list={["tag", { press: item.data.category === "Press Release", technical: item.data.category === "Technical" }]}>{item.data.category}</span>
              <h3>{item.data.title}</h3>
              <p>{item.data.excerpt}</p>
              <time datetime={item.data.date.toISOString()}>{formatDate(item.data.date)}</time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="callout">
        <div>
          <span>Investor Access</span>
          <h2>Position yourself before the market catches up.</h2>
          <p>Explore the investor deck or get in touch to learn more about the Argentina copper opportunity.</p>
        </div>
        <a class="button primary" href="/investor">View Investor Materials</a>
      </div>
    </div>
  </section>
</BaseLayout>
