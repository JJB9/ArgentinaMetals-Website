---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path}`;
const news = (await getCollection("news"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) => date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});

const heroStats = [
  ["146k+", "Hectares Controlled"],
  ["26", "Project Areas", "copper"],
  ["#7", "Global Copper Rank"],
  ["~60%", "Insider Ownership", "copper"]
];

const tickerItems = [
  { text: "Copper Price", strong: "$4.85/lb" },
  { text: "146,000+ Hectares" },
  { text: "26 Project Areas" },
  { text: "San Juan & Catamarca Provinces" },
  { text: "Andean Copper Belt" },
  { text: "NI 43-101 Technical Report Filed" },
  { text: "Up to", strong: "9,978 ppm Cu at Las Estrellas" }
];

const bentoCards = [
  { icon: "landscape", title: "Same Geology", text: "Argentina shares the high-grade Andean belt with Chile — the world's #1 producer — yet remains chronically underexplored with a fraction of the capital invested." },
  { icon: "trending_up", title: "Mining Reset", text: "President Milei's pro-business reforms are sparking a structural re-rating of Argentine mining assets across every stage of development.", variant: "dark" },
  { icon: "zoom_out_map", title: "District Scale", text: "Amassing 146,000+ hectares across prime districts before the surge in major M&A activity reshapes the region.", variant: "copper" }
];

const mileiSteps = [
  { year: "Capital Controls Lifted", title: "Free Flow of Investment", desc: "Elimination of capital controls incentivizes major foreign direct investment into Argentine mining for the first time in a generation." },
  { year: "RIGI Implementation", title: "30-Year Tax Stability", desc: "The Large Investment Incentive Regime (RIGI) guarantees fiscal predictability — a transformational shift for long-cycle mining projects." },
  { year: "Provincial Alignment", title: "Pro-Mining Governance", desc: "Key provinces like San Juan and Catamarca are actively courting developers with streamlined permitting and infrastructure support." }
];

const counters = [
  { val: "80", lbl: "New Mines Needed", desc: "Required by 2030 to meet basic energy-transition demand." },
  { val: "3-4x", lbl: "Copper per EV", desc: "Electric vehicles consume multiples of the copper used in ICE vehicles." },
  { val: "16yr", lbl: "Discovery to Production", desc: "The timeline to bring new supply online is longer than ever." },
  { val: "-20%", lbl: "Grade Decline", desc: "Existing majors face sustained drops in ore quality across the board." }
];

const checklist = [
  "Elite prospects at entry-level pricing",
  "One of the largest private land packages in the region",
  "Multi-decade exploration runway across prime belts",
  "Drill targets confirmed by magnetometric survey"
];

const [featured, ...sideNews] = news;
---

<BaseLayout
  title="Argentina Metals Corp. - A Pure-Play on Argentina's Copper Boom"
  description="Argentina Metals Corp. is acquiring district-scale copper exploration assets across Argentina's underexplored Andean copper belts."
>
  <div class="page-home2">
    <header class="h2-hero">
      <div class="h2-hero-inner">
        <div class="h2-hero-content">
          <span class="h2-hero-tag">TSX-V: VLLC</span>
          <h1>A Pure-Play on Argentina's <em>Copper Boom</em></h1>
          <p class="h2-hero-sub">Acquiring premium assets in the world's #7 copper region while the market re-prices the "Milei Effect."</p>
          <div class="h2-hero-ctas">
            <a class="h2-btn h2-btn-copper-grad h2-btn-lg" href="#thesis">Explore the Opportunity <span class="mi" aria-hidden="true">arrow_forward</span></a>
            <a class="h2-btn h2-btn-out-white h2-btn-lg" href="/investor">View Investor Deck</a>
          </div>
        </div>
        <div class="h2-hero-video">
          <video autoplay muted loop playsinline src={asset("assets/images/case-video.mp4")}></video>
        </div>
      </div>
      <div class="h2-hero-bottom">
        <div class="h2-hero-stats">
          {heroStats.map(([val, lbl, variant]) => (
            <div>
              <span class:list={["h2-hero-stat-val", variant]}>{val}</span>
              <span class="h2-hero-stat-lbl">{lbl}</span>
            </div>
          ))}
        </div>
      </div>
    </header>

    <div class="h2-ticker" aria-hidden="true">
      <div class="h2-ticker-track">
        {[...tickerItems, ...tickerItems].map((item) => (
          <span class="h2-ticker-item">
            <span class="h2-ticker-dot"></span>
            {item.text}{item.strong && <> <strong>{item.strong}</strong></>}
          </span>
        ))}
      </div>
    </div>

    <section class="h2-sec" id="thesis">
      <div class="h2-wrap">
        <span class="h2-sec-label">01 — The Thesis</span>
        <h2 class="h2-sec-title">Three pillars define our approach to the Argentine copper boom.</h2>
        <p class="h2-sec-desc">A strategy built on geology, policy, and scale — before the rush begins.</p>

        <div class="h2-bento">
          {bentoCards.map((c) => (
            <article class:list={["h2-bento-card", c.variant]}>
              <span class="h2-bento-ic">{c.icon}</span>
              <h3>{c.title}</h3>
              <p>{c.text}</p>
            </article>
          ))}
          <article class="h2-bento-card span2">
            <div class="h2-bento-split">
              <div>
                <span class="h2-bento-val copper">$30B+</span>
                <p>Regional investment pipeline announced by majors for Argentine copper-gold projects over the coming decade.</p>
              </div>
              <div>
                <span class="h2-bento-val">#7</span>
                <p>Argentina's global ranking for copper reserve potential — virtually untouched compared to #1 neighbor Chile.</p>
              </div>
            </div>
          </article>
          <article class="h2-bento-card">
            <span class="h2-bento-ic">verified</span>
            <h3>NI 43-101 Filed</h3>
            <p>Independent technical report completed covering the full 146,728-hectare land package across 26 project areas.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="h2-sec h2-timeline-sec">
      <div class="h2-wrap">
        <div class="h2-timeline-header">
          <div>
            <span class="h2-sec-label">02 — The Milei Effect</span>
            <h2 class="h2-sec-title">From overlooked to essential.</h2>
            <p class="h2-sec-desc" style="margin-bottom:0">Decades of political instability kept capital out of Argentina, creating a profound valuation gap. That gap is closing fast — and early movers capture the arbitrage.</p>
          </div>
          <div class="h2-top10">
            <span class="h2-top10-val">Top 10</span>
            <span class="h2-top10-lbl">Global Copper Reserves</span>
          </div>
        </div>

        <div class="h2-timeline">
          {mileiSteps.map((step) => (
            <div class="h2-tl-item">
              <div class="h2-tl-dot"></div>
              <span class="h2-tl-year">{step.year}</span>
              <h3 class="h2-tl-title">{step.title}</h3>
              <p class="h2-tl-desc">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="h2-sec h2-dark-sec">
      <div class="h2-wrap">
        <span class="h2-sec-label">03 — The Electrification Metal</span>
        <h2 class="h2-sec-title">The world cannot decarbonize without copper.</h2>
        <p class="h2-sec-desc">A structural deficit driven by unprecedented demand and anemic new supply. The squeeze is here.</p>

        <div class="h2-counters">
          {counters.map((c) => (
            <div class="h2-counter">
              <div class="h2-counter-val">{c.val}</div>
              <div class="h2-counter-lbl">{c.lbl}</div>
              <div class="h2-counter-desc">{c.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="h2-sec">
      <div class="h2-wrap">
        <div class="h2-split2">
          <div class="h2-split2-img">
            <img src={asset("assets/images/rock-quarry-geology.jpg")} alt="Andean copper belt landscape" loading="lazy" />
            <div class="h2-split2-badge">
              <span class="h2-sv">146k+</span>
              <span class="h2-sl">Hectares Controlled</span>
            </div>
          </div>
          <div class="h2-split2-text">
            <span class="h2-sec-label">04 — The Opportunity</span>
            <h3>The rocks don't know they crossed a border.</h3>
            <p>Chile has mined their side of the Andes for a century. Argentina's side is virtually untouched — yet shares the same geological belt, the same intrusive history, and the same copper-gold endowment.</p>
            <ul class="h2-checklist">
              {checklist.map((item) => (
                <li><span class="h2-check-ic">check_circle</span>{item}</li>
              ))}
            </ul>
            <a class="h2-btn h2-btn-outline" href="/projects">Explore Our Projects <span class="mi" aria-hidden="true">arrow_forward</span></a>
          </div>
        </div>
      </div>
    </section>

    <section class="h2-sec h2-news-sec">
      <div class="h2-wrap">
        <span class="h2-sec-label">05 — Latest News</span>
        <h2 class="h2-sec-title">Recent updates from Argentina Metals.</h2>
        <p class="h2-sec-desc">Press releases and corporate developments.</p>

        <div class="h2-news-mag">
          {featured && (
            <a class="h2-news-feat" href="/news">
              <div class="h2-news-feat-img">
                <img src={featured.data.image ?? asset("assets/images/rock-quarry-geology.jpg")} alt={featured.data.imageAlt ?? featured.data.title} loading="lazy" />
              </div>
              <div class="h2-news-feat-body">
                <span class="h2-news-feat-tag">{featured.data.category}</span>
                <h3>{featured.data.title}</h3>
                <p>{featured.data.excerpt}</p>
                <span class="h2-news-feat-date">{formatDate(featured.data.date)}</span>
              </div>
            </a>
          )}
          <div class="h2-news-side">
            {sideNews.slice(0, 2).map((item) => (
              <a class="h2-news-sm" href="/news">
                <span class:list={["h2-news-sm-tag", item.data.category === "Press Release" ? "press" : "update"]}>
                  {item.data.category === "Press Release" ? "Press Release" : "Corporate"}
                </span>
                <h3>{item.data.title}</h3>
                <p>{item.data.excerpt}</p>
                <span class="h2-news-sm-date">{formatDate(item.data.date)}</span>
              </a>
            ))}
          </div>
        </div>

        <a class="h2-news-sec-link" href="/news">View All News <span class="mi" aria-hidden="true">arrow_forward</span></a>
      </div>
    </section>

    <section class="h2-cta-banner">
      <h2>Position yourself before the market catches up.</h2>
      <p>Explore the investor deck or get in touch to learn more about the Argentina copper opportunity.</p>
      <div class="h2-cta-actions">
        <a class="h2-btn h2-btn-copper-grad h2-btn-lg" href="/investor">View Investor Deck <span class="mi" aria-hidden="true">arrow_forward</span></a>
        <a class="h2-btn h2-btn-out-white h2-btn-lg" href="/contact">Contact Us</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page-home2 { background: var(--surface); }
  .page-home2 .h2-wrap { max-width: 1240px; margin: 0 auto; padding: 0 48px; }

  .page-home2 .h2-btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-weight: 600; font-size: 0.82rem; cursor: pointer; border: 1.5px solid transparent; border-radius: 10px; padding: 12px 28px; line-height: 1.3; transition: all 0.25s var(--ease); position: relative; overflow: hidden; text-decoration: none; }
  .page-home2 .h2-btn-lg { padding: 16px 36px; font-size: 0.9rem; border-radius: 14px; }
  .page-home2 .h2-btn-copper-grad { background: var(--copper-grad); color: #fff; border: none; padding: 13.5px 28px; }
  .page-home2 .h2-btn-copper-grad.h2-btn-lg { padding: 17.5px 36px; }
  .page-home2 .h2-btn-copper-grad:hover { box-shadow: 0 8px 24px rgba(197, 100, 43, 0.35); }
  .page-home2 .h2-btn-out-white { background: transparent; color: #fff; border-color: rgba(255, 255, 255, 0.3); }
  .page-home2 .h2-btn-out-white:hover { background: rgba(255, 255, 255, 0.08); border-color: #fff; }
  .page-home2 .h2-btn-outline { background: transparent; color: var(--green); border-color: var(--green); }
  .page-home2 .h2-btn-outline:hover { background: var(--green); color: #fff; }

  .page-home2 .h2-hero { position: relative; background: var(--g900); overflow: hidden; }
  .page-home2 .h2-hero-inner { max-width: 1240px; margin: 0 auto; padding: 88px 48px; display: grid; grid-template-columns: 1fr 1.1fr; gap: 64px; align-items: center; }
  .page-home2 .h2-hero-content { position: relative; z-index: 2; }
  .page-home2 .h2-hero-tag { display: inline-flex; align-items: center; gap: 8px; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--copper-light); margin-bottom: 28px; padding: 7px 16px; background: rgba(253, 180, 115, 0.1); border: 1px solid rgba(253, 180, 115, 0.15); border-radius: 9999px; }
  .page-home2 .h2-hero h1 { font-weight: 700; font-size: 4.2rem; line-height: 1; letter-spacing: -0.03em; color: #fff; margin-bottom: 24px; max-width: none; }
  .page-home2 .h2-hero h1 em { font-style: normal; background: var(--copper-grad); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; color: transparent; }
  .page-home2 .h2-hero-sub { font-weight: 300; font-size: 1.05rem; color: rgba(255, 255, 255, 0.55); max-width: 460px; line-height: 1.8; margin-bottom: 36px; }
  .page-home2 .h2-hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }
  .page-home2 .h2-hero-video { position: relative; border-radius: 28px; overflow: hidden; aspect-ratio: 16 / 10; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.4); background: #000; }
  .page-home2 .h2-hero-video video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .page-home2 .h2-hero-bottom { max-width: 1240px; margin: 0 auto; padding: 0 48px 72px; }
  .page-home2 .h2-hero-stats { display: flex; gap: 48px; padding-top: 40px; border-top: 1px solid rgba(255, 255, 255, 0.08); }
  .page-home2 .h2-hero-stat-val { display: block; font-weight: 700; font-size: 2rem; color: #fff; line-height: 1; margin-bottom: 6px; }
  .page-home2 .h2-hero-stat-val.copper { color: var(--copper-light); }
  .page-home2 .h2-hero-stat-lbl { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255, 255, 255, 0.4); }

  .page-home2 .h2-ticker { background: var(--g900); border-bottom: 1px solid rgba(255, 255, 255, 0.06); overflow: hidden; padding: 14px 0; }
  .page-home2 .h2-ticker-track { display: flex; animation: h2-scroll 40s linear infinite; width: max-content; }
  .page-home2 .h2-ticker-item { display: flex; align-items: center; gap: 10px; padding: 0 48px; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--g400); white-space: nowrap; }
  .page-home2 .h2-ticker-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--copper); display: inline-block; flex-shrink: 0; }
  .page-home2 .h2-ticker-item strong { color: var(--copper-light); font-weight: 700; }
  @keyframes h2-scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  .page-home2 .h2-sec { padding: 128px 0; position: relative; background: var(--surface); }
  .page-home2 .h2-sec-label { display: inline-flex; align-items: center; gap: 10px; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--copper-dark); margin-bottom: 20px; }
  .page-home2 .h2-sec-label::before { content: ""; display: block; width: 32px; height: 2px; background: var(--copper-grad); border-radius: 2px; }
  .page-home2 .h2-sec-title { font-weight: 600; font-size: 2.6rem; line-height: 1.1; letter-spacing: -0.02em; color: var(--g900); margin-bottom: 16px; max-width: 680px; }
  .page-home2 .h2-sec-desc { font-weight: 300; font-size: 1rem; color: var(--g500); max-width: 560px; line-height: 1.8; margin-bottom: 64px; }

  .page-home2 .h2-bento { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
  .page-home2 .h2-bento-card { background: var(--white); border: 1px solid var(--g100); border-radius: 20px; padding: 40px 36px; display: flex; flex-direction: column; transition: all 0.3s var(--ease); }
  .page-home2 .h2-bento-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); border-color: transparent; }
  .page-home2 .h2-bento-card.span2 { grid-column: span 2; }
  .page-home2 .h2-bento-card.dark { background: var(--g900); border-color: var(--g800); }
  .page-home2 .h2-bento-card.dark h3, .page-home2 .h2-bento-card.dark .h2-bento-val { color: #fff; }
  .page-home2 .h2-bento-card.dark p { color: var(--g400); }
  .page-home2 .h2-bento-card.copper { background: var(--copper-grad); border-color: transparent; }
  .page-home2 .h2-bento-card.copper h3, .page-home2 .h2-bento-card.copper .h2-bento-val { color: #fff; }
  .page-home2 .h2-bento-card.copper p { color: rgba(255, 255, 255, 0.75); }
  .page-home2 .h2-bento-ic { font-family: "Material Symbols Outlined"; font-variation-settings: "FILL" 1; font-size: 1.6rem; color: var(--copper); margin-bottom: 20px; line-height: 1; }
  .page-home2 .h2-bento-card.dark .h2-bento-ic { color: var(--copper-light); }
  .page-home2 .h2-bento-card.copper .h2-bento-ic { color: rgba(255, 255, 255, 0.8); }
  .page-home2 .h2-bento-card h3 { font-weight: 600; font-size: 1.15rem; color: var(--g900); margin-bottom: 10px; line-height: 1.3; letter-spacing: -0.005em; }
  .page-home2 .h2-bento-card p { font-size: 0.88rem; color: var(--g500); line-height: 1.75; flex: 1; }
  .page-home2 .h2-bento-val { font-weight: 700; font-size: 3rem; color: var(--g900); line-height: 1; margin-bottom: 8px; letter-spacing: -0.02em; display: block; }
  .page-home2 .h2-bento-val.copper { color: var(--copper-dark); }
  .page-home2 .h2-bento-split { display: flex; gap: 48px; align-items: center; flex-wrap: wrap; }
  .page-home2 .h2-bento-split > div { flex: 1 1 220px; }

  .page-home2 .h2-timeline-sec { background: var(--warm); }
  .page-home2 .h2-timeline-header { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; margin-bottom: 80px; }
  .page-home2 .h2-top10 { display: flex; flex-direction: column; gap: 12px; padding-top: 40px; }
  .page-home2 .h2-top10-val { font-weight: 700; font-size: 2.6rem; color: var(--copper-dark); line-height: 1; }
  .page-home2 .h2-top10-lbl { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--g500); }
  .page-home2 .h2-timeline { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; position: relative; }
  .page-home2 .h2-timeline::before { content: ""; position: absolute; top: 28px; left: 0; right: 0; height: 2px; background: var(--g200); }
  .page-home2 .h2-tl-item { position: relative; padding: 0 32px; }
  .page-home2 .h2-tl-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--copper-grad); margin-bottom: 28px; position: relative; z-index: 2; box-shadow: 0 0 0 5px var(--warm); }
  .page-home2 .h2-tl-year { font-weight: 700; font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--copper-dark); margin-bottom: 12px; display: block; }
  .page-home2 .h2-tl-title { font-weight: 600; font-size: 1.05rem; color: var(--g900); margin-bottom: 8px; line-height: 1.3; }
  .page-home2 .h2-tl-desc { font-size: 0.85rem; color: var(--g500); line-height: 1.75; }

  .page-home2 .h2-dark-sec { background: var(--g900); position: relative; overflow: hidden; }
  .page-home2 .h2-dark-sec::before { content: ""; position: absolute; top: -400px; right: -200px; width: 800px; height: 800px; border-radius: 50%; background: radial-gradient(circle, rgba(197, 100, 43, 0.08) 0%, transparent 70%); pointer-events: none; }
  .page-home2 .h2-dark-sec .h2-sec-label { color: var(--copper-light); }
  .page-home2 .h2-dark-sec .h2-sec-label::before { background: var(--copper-light); }
  .page-home2 .h2-dark-sec .h2-sec-title { color: #fff; }
  .page-home2 .h2-dark-sec .h2-sec-desc { color: var(--g400); }
  .page-home2 .h2-counters { display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px; position: relative; z-index: 2; }
  .page-home2 .h2-counter { text-align: center; }
  .page-home2 .h2-counter-val { font-weight: 800; font-size: 4rem; line-height: 1; background: var(--copper-grad); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; color: transparent; margin-bottom: 12px; letter-spacing: -0.02em; }
  .page-home2 .h2-counter-lbl { font-weight: 600; font-size: 0.92rem; color: #fff; margin-bottom: 6px; }
  .page-home2 .h2-counter-desc { font-size: 0.82rem; color: var(--g400); line-height: 1.6; max-width: 240px; margin: 0 auto; }

  .page-home2 .h2-split2 { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .page-home2 .h2-split2-img { position: relative; border-radius: 28px; overflow: hidden; aspect-ratio: 4 / 3; box-shadow: var(--shadow-lg); background: var(--sand); }
  .page-home2 .h2-split2-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .page-home2 .h2-split2-badge { position: absolute; bottom: 24px; left: 24px; background: rgba(255, 255, 255, 0.94); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); padding: 20px 24px; border-radius: 14px; box-shadow: 0 6px 20px rgba(10, 10, 9, 0.06); }
