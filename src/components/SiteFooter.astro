---
import { Image } from "astro:assets";
import brandLogo from "@assets/images/argentina-metals-copper-white.webp";
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <Image src={brandLogo} alt="Argentina Metals Corp." width={152} height={94} densities={[1, 2]} loading="lazy" decoding="async" />
      </div>
      <nav class="footer-col" aria-label="Company">
        <h2>Company</h2>
        <a href="/team">Team</a>
        <a href="/news">News</a>
        <a href="/contact">Contact</a>
        <a href="/investor">Investor Relations</a>
      </nav>
      <nav class="footer-col" aria-label="Projects">
        <h2>Projects</h2>
        <a href="/projects">All Projects</a>
        <a href="/projects/las-estrellas">Las Estrellas</a>
      </nav>
      <nav class="footer-col" aria-label="Legal">
        <h2>Legal</h2>
        <a href="/disclaimer">Disclaimer</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Use</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <p>© 2026 Argentina Metals Corp. All rights reserved.</p>
      <ul class="footer-social" aria-label="Social media">
        <li>
          <a href="https://www.linkedin.com/company/argentina-metals-corp" aria-label="LinkedIn" rel="noopener noreferrer" target="_blank">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.28 2.38 4.28 5.47v6.27zM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z" />
            </svg>
          </a>
        </li>
        <li>
          <a href="https://x.com/ArgentinaMetals" aria-label="X" rel="noopener noreferrer" target="_blank">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25h6.83l4.713 6.231 5.447-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644z" />
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>
