    <div class="footer-top">
      <div class="footer-brand">
        <Image src={logoCopperGreen} alt="Argentina Metals Corp." width={152} height={94} densities={[1, 2]} loading="lazy" decoding="async" />
      </div>
      <div class="footer-links">
        <div>
          <a href="/company">Company</a>
          <a href="/investor">Investor Relations</a>
          <a href="/news">News</a>
          <a href="/contact">Contact</a>
        </div>
        <div>
          <a href="/projects">All Projects</a>
          <a href="/projects/las-estrellas">Las Estrellas</a>
        </div>
        <div>
          <a href="/disclaimer">Disclaimer</a>
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Use</a>
        </div>
      </div>
    </div>
    <p class="footer-bottom">© 2026 Argentina Metals Corp. All rights reserved.</p>
  </div>
</footer>
