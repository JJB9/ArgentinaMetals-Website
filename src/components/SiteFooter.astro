---
const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path}`;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <img src={asset("assets/images/logo-copper-green.png")} alt="Argentina Metals Corp." width="152" height="94" loading="lazy" decoding="async" />
      </div>
      <div class="footer-links">
        <div>
          <a href="/company">Company</a>
          <a href="/investor">Investor Relations</a>
          <a href="/news">News</a>
          <a href="/contact">Contact</a>
        </div>
        <div>
          <a href="/projects">All Projects</a>
          <a href="/projects/las-estrellas">Las Estrellas</a>
        </div>
        <div>
          <a href="/disclaimer">Disclaimer</a>
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Use</a>
        </div>
      </div>
    </div>
    <p class="footer-bottom">© 2026 Argentina Metals Corp. All rights reserved.</p>
  </div>
</footer>
