---
interface Props {
  title?: string;
  description?: string;
  variant?: "card" | "inline";
  reveal?: boolean;
  revealIndex?: number;
}

const {
  title = "Subscribe to Investor Alerts",
  description,
  variant = "card",
  reveal = false,
  revealIndex = 0
} = Astro.props;
const revealAttrs = reveal ? { "data-reveal": "", style: `--i:${revealIndex}` } : {};
---

<div class:list={["subscribe-card", { "subscribe-card--inline": variant === "inline" }]} {...revealAttrs}>
  <div class="subscribe-head">
    {variant === "card" && <span class="subscribe-icon mi" aria-hidden="true">mail</span>}
    <h2>{title}</h2>
  </div>
  {description && <p class="subscribe-desc">{description}</p>}
  <form class="newsletter-form" data-newsletter-form novalidate>
    <label class="sr-only" for="newsletter-email">Email address</label>
    <input
      id="newsletter-email"
      class="form-input"
      type="email"
      name="email"
      autocomplete="email"
      placeholder="you@email.com"
      required
    />
    <button class="button copper" type="submit">
      <span class="newsletter-btn-label">Subscribe</span>
      <span class="mi" aria-hidden="true">arrow_forward</span>
    </button>
    <p class="newsletter-status" data-newsletter-status role="status" aria-live="polite" hidden></p>
  </form>
</div>

<style>
  .subscribe-card {
    width: 100%;
    padding: 32px;
    border: 1px solid var(--g100);
    border-radius: var(--r-xl);
    background: var(--white);
    box-shadow: var(--s-sm);
    transition: box-shadow 220ms var(--ease), transform 220ms var(--ease);
  }

  .subscribe-card:hover {
    box-shadow: var(--s-md);
  }

  .subscribe-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }

  .subscribe-icon {
    display: inline-grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: var(--r-md);
    background: var(--copper-wash);
    color: var(--copper-dark);
    font-size: 1.05rem;
  }

  .subscribe-card h2 {
    margin: 0;
    color: var(--g900);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .subscribe-card .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .subscribe-card .form-input {
    width: 100%;
  }

  .subscribe-card .button.copper {
    width: 100%;
    padding: 13px 22px;
  }

  .subscribe-card .button.copper .mi {
    font-size: 1.05rem;
    transition: transform 220ms var(--ease);
  }

  .subscribe-card .button.copper:hover .mi {
    transform: translateX(3px);
  }

  .subscribe-desc {
    margin: 0 0 22px;
    color: var(--g500);
    font-size: 0.9rem;
    line-height: 1.7;
    max-width: 42ch;
  }

  .subscribe-card--inline {
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .subscribe-card--inline:hover {
    box-shadow: none;
  }

  .subscribe-card--inline h2 {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.012em;
    line-height: 1.2;
  }

  .subscribe-card--inline .newsletter-form {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
  }

  .subscribe-card--inline .form-input {
    flex: 1 1 180px;
    width: auto;
    min-width: 0;
    border: none;
    border-bottom: 1px solid var(--g200);
    border-radius: 0;
    background: transparent;
    padding: 11px 2px;
    font-size: 0.92rem;
  }

  .subscribe-card--inline .form-input:focus,
  .subscribe-card--inline .form-input:focus-visible {
    outline: none;
    border-color: var(--copper-dark);
    box-shadow: 0 1px 0 0 var(--copper-dark);
    background: transparent;
  }

  .subscribe-card--inline .button.copper {
    flex: none;
    width: auto;
    padding: 12px 24px;
    border-radius: var(--r-full);
  }

  .subscribe-card--inline .newsletter-status {
    flex-basis: 100%;
  }

  .newsletter-status {
    margin: 4px 0 0;
    padding: 10px 12px;
    border-radius: var(--r-md);
    background: var(--copper-wash);
    color: var(--copper-dark);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .newsletter-status.err {
    background: #fdecec;
    color: #b1322f;
  }

  .newsletter-form[data-state="loading"] .button {
    opacity: 0.7;
    pointer-events: none;
  }

  .newsletter-form[data-state="success"] .form-input,
  .newsletter-form[data-state="success"] .button {
    display: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script is:inline>
  (() => {
    if (window.__subscribeCardInit) return;
    window.__subscribeCardInit = true;

    const bind = (form) => {
      if (form.dataset.bound) return;
      form.dataset.bound = "1";
      const status = form.querySelector("[data-newsletter-status]");
      const input = form.querySelector('input[type="email"]');

      const show = (msg, kind) => {
        if (!status) return;
        status.textContent = msg;
        status.classList.toggle("err", kind === "err");
        status.hidden = false;
      };

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (form.dataset.state === "loading" || form.dataset.state === "success") return;

        const email = (input && input.value || "").trim();
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          show("Please enter a valid email address.", "err");
          return;
        }

        form.dataset.state = "loading";
        try {
          const res = await fetch("/api/subscribe", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email })
          });
          if (!res.ok) throw new Error("Request failed");
          form.dataset.state = "success";
          show("Thanks. Check your inbox for a confirmation link to finish subscribing.", "ok");
        } catch {
          form.dataset.state = "";
          show("Something went wrong. Please try again in a moment.", "err");
        }
      });
    };

    document.querySelectorAll("[data-newsletter-form]").forEach(bind);
  })();
</script>
