---
export interface KeyFact {
  icon: string;
  label: string;
  value: string;
  highlight?: boolean;
}

interface Props {
  title?: string;
  lede?: string;
  facts: KeyFact[];
  footnote?: string;
  columns?: 2 | 3 | 4;
}

const { title = "Key Facts", lede, facts, footnote, columns = 4 } = Astro.props;
---

<section class:list={["key-facts", `key-facts--cols-${columns}`]} aria-label={title} data-reveal>
  <div class="key-facts-head">
    <h2>{title}</h2>
    {lede && <p>{lede}</p>}
  </div>
  <div class="key-facts-grid" role="list">
    {facts.map((fact) => (
      <div class:list={["kf-item", { "kf-item--hi": fact.highlight }]} role="listitem">
        <span class="kf-icon" aria-hidden="true">
          <span class="mi">{fact.icon}</span>
        </span>
        <div class="kf-text">
          <span class="kf-label">{fact.label}</span>
          <span class="kf-value">{fact.value}</span>
        </div>
      </div>
    ))}
  </div>
  {footnote && <p class="key-facts-foot">{footnote}</p>}
</section>
