---
export interface KeyFact {
  label: string;
  value: string;
  highlight?: boolean;
}

interface Props {
  title?: string;
  lede?: string;
  facts: KeyFact[];
  footnote?: string;
  columns?: 2 | 3 | 4;
}

const { title = "Key Facts", lede, facts, footnote, columns = 4 } = Astro.props;
---

<section class:list={["key-facts", `key-facts--cols-${columns}`]} aria-label={title} data-reveal>
  <div class="key-facts-head">
    <h2>{title}</h2>
    {lede && <p>{lede}</p>}
  </div>
  <dl class="key-facts-grid">
    {facts.map((fact) => (
      <div class:list={["kf-item", { "kf-item--hi": fact.highlight }]}>
        <dt class="kf-label">{fact.label}</dt>
        <dd class="kf-value">{fact.value}</dd>
      </div>
    ))}
  </dl>
  {footnote && <p class="key-facts-foot">{footnote}</p>}
</section>
