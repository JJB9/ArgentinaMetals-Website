---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  title: string;
  text: string;
  image?: string;
  imageAlt?: string;
  stats?: Stat[];
}

const { title, text, image, imageAlt, stats } = Astro.props;
const hasStats = Array.isArray(stats) && stats.length > 0;
const split = Boolean(image);
---

<section class:list={["page-hero", { "page-hero--split": split }]}>
  <div class="wrap">
    <div class="page-hero-text">
      <h1 data-reveal style="--i:0">{title}</h1>
      <p data-reveal style="--i:1">{text}</p>
      {hasStats && (
        <div class="page-hero-stats" data-reveal style="--i:2">
          {stats!.map((stat) => (
            <div class="page-hero-stat">
              <span class="page-hero-stat-value">{stat.value}</span>
              <span class="page-hero-stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      )}
      <slot />
    </div>
    {image && (
      <div class="page-hero-right">
        <div class="page-hero-img" data-parallax>
          <img src={image} alt={imageAlt ?? ""} width="1200" height="900" loading="eager" />
        </div>
        <slot name="image-bottom" />
      </div>
    )}
  </div>
</section>
