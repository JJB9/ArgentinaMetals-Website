---
interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path}`;
const normalize = (href: string) => href === "/" ? "/" : href.replace(/\/$/, "");
const currentPath = normalize(pathname);

const isHome = currentPath === "/" || currentPath === "/home2";
const brandSrc = isHome ? "assets/images/logo-copper-green.png" : "assets/images/icon-copper-green.png";
const brandDims = isHome ? { width: 140, height: 87 } : { width: 87, height: 80 };

const navItems = [
  { label: "Home", href: "/" },
  { label: "Home v2", href: "/home2" },
  { label: "Company", href: "/company" },
  { label: "Projects", href: "/projects" },
  { label: "Investors", href: "/investor" },
  { label: "News", href: "/news" },
  { label: "Contact", href: "/contact" }
];
---

<header class:list={["site-header", { "site-header-feature": isHome }]}>
  <a class:list={["site-brand", { "site-brand-icon": !isHome }]} href="/" aria-label="Argentina Metals home">
    <img src={asset(brandSrc)} alt="Argentina Metals Corp." width={brandDims.width} height={brandDims.height} fetchpriority="high" decoding="async" />
  </a>
  <nav class="site-nav" aria-label="Primary navigation">
    {navItems.map((item) => (
      <a class:list={{ active: normalize(item.href) === currentPath }} href={item.href}>{item.label}</a>
    ))}
  </nav>
</header>
