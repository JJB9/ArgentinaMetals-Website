---
import { Image } from "astro:assets";
import logoCopperGreen from "@assets/images/logo-copper-green.png";
import iconCopperGreen from "@assets/images/icon-copper-green.png";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const normalize = (href: string) => href === "/" ? "/" : href.replace(/\/$/, "");
const currentPath = normalize(pathname);

const isHome = currentPath === "/";
const brandImage = isHome ? logoCopperGreen : iconCopperGreen;
const brandDims = isHome ? { width: 140, height: 87 } : { width: 69, height: 64 };

const navItems = [
  { label: "Home", href: "/" },
  { label: "Company", href: "/company" },
  { label: "Projects", href: "/projects" },
  { label: "Investors", href: "/investor" },
  { label: "News", href: "/news" },
  { label: "Contact", href: "/contact" }
];
---

<header class:list={["site-header", { "site-header-feature": isHome }]}>
  <a class:list={["site-brand", { "site-brand-icon": !isHome }]} href="/" aria-label="Argentina Metals home">
    <Image src={brandImage} alt="Argentina Metals Corp." width={brandDims.width} height={brandDims.height} densities={[1, 2]} loading="eager" fetchpriority="high" decoding="async" />
  </a>
  <nav class="site-nav" aria-label="Primary navigation">
    {navItems.map((item) => (
      <a class:list={{ active: normalize(item.href) === currentPath }} href={item.href}>{item.label}</a>
    ))}
  </nav>
</header>
