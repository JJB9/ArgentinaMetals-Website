---
interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path}`;
const normalize = (href: string) => href === "/" ? "/" : href.replace(/\/$/, "");
const currentPath = normalize(pathname);

const navItems = [
  { label: "Home", href: "/" },
  { label: "Company", href: "/company" },
  { label: "Projects", href: "/projects" },
  { label: "Investors", href: "/investor" },
  { label: "News", href: "/news" },
  { label: "Contact", href: "/contact" }
];
---

<header class="site-header">
  <a class="site-brand" href="/" aria-label="Argentina Metals home">
    <img src={asset("assets/images/logo-copper-green.png")} alt="Argentina Metals Corp." />
  </a>
  <nav class="site-nav" aria-label="Primary navigation">
    {navItems.map((item) => (
      <a class:list={{ active: normalize(item.href) === currentPath }} href={item.href}>{item.label}</a>
    ))}
  </nav>
</header>
